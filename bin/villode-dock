    "files": ("文件", "finder.png", "org.gnome.Nautilus"),
    "launcher": ("启动台", "launchpad.png", "applications-all"),
    "terminal": ("终端", "terminal.png", "Alacritty"),
    "browser": ("浏览器", "chrome.png", "google-chrome"),
