    "builtin:files",
    "builtin:launcher",
    "builtin:terminal",
    "builtin:browser",
]
BUILTIN_DESKTOP_IDS = {
    "org.gnome.nautilus.desktop": "files",
    "villode-launcher.desktop": "launcher",
    "alacritty.desktop": "terminal",
    "google-chrome.desktop": "browser",
    "com.google.chrome.desktop": "browser",
}
MAX_PINNED_ITEMS = 20

# These are window classes, not process names.  In particular, the launcher has
# a background daemon which must not count as a visible/running Dock item.
RUNNING_CLASSES = {
    "files": (
        "org.gnome.nautilus",
        "nautilus",
        "org.kde.dolphin",
        "dolphin",
        "thunar",
        "nemo",
        "pcmanfm",
        "pcmanfm-qt",
    ),
    "launcher": ("local.villode.launcher",),
    "terminal": ("alacritty", "foot", "kitty", "org.wezfurlong.wezterm", "konsole"),
    "browser": ("google-chrome", "google-chrome-stable"),
}
FOCUSABLE = frozenset(RUNNING_CLASSES)

# Transient / shell surfaces that must never appear as running Dock apps.
SKIP_RUNNING_CLASSES = frozenset(
    {
        "villode-dock",
        "local.villode.dock",
        "local.villode.launcher",
        "quickshell",
        "qs",
        "xdg-desktop-portal-gtk",
        "xdg-desktop-portal-hyprland",
        "polkit-gnome-authentication-agent-1",
        "nm-applet",
    }
)

# Cache: lowercase wm class / exec name → desktop_id
_DESKTOP_CLASS_INDEX = None


def color_from_hex(value, fallback):
    if not isinstance(value, str):
        return fallback
    value = value.lstrip("#")
    if len(value) != 6 or not re.fullmatch(r"[0-9a-fA-F]{6}", value):
        return fallback
    return tuple(int(value[index : index + 2], 16) / 255.0 for index in range(0, 6, 2))


def hex_from_color(color):
    return "#{:02x}{:02x}{:02x}".format(
        *(max(0, min(255, round(component * 255))) for component in color)
    )


def terminal_command():
    """Return the terminal selected in Caelestia's default-app settings."""
    try:
        data = json.loads(CAELESTIA_CONFIG.read_text())
        command = data["general"]["apps"]["terminal"]
        if (
            isinstance(command, list)
            and command
            and all(isinstance(argument, str) and argument for argument in command)
            and shutil.which(command[0])
        ):
            return command
    except (FileNotFoundError, KeyError, OSError, TypeError, ValueError, json.JSONDecodeError):
        pass

    for candidate in ("alacritty", "foot", "kitty", "xterm"):
        if shutil.which(candidate):
            return [candidate]
    return ["alacritty"]


def terminal_window_classes(command):
    name = Path(command[0]).name if command else ""
    return {
        "alacritty": ("alacritty",),
        "foot": ("foot",),
        "kitty": ("kitty",),
        "wezterm": ("org.wezfurlong.wezterm", "wezterm"),
        "konsole": ("org.kde.konsole", "konsole"),
        "gnome-terminal": ("org.gnome.terminal", "gnome-terminal-server"),
        "kgx": ("org.gnome.console", "kgx"),
        "xfce4-terminal": ("xfce4-terminal",),
        "xterm": ("xterm",),
    }.get(name, (name.lower(),))


def browser_command():
    try:
        data = json.loads(CAELESTIA_CONFIG.read_text())
        command = data["general"]["apps"]["browser"]
        if (
            isinstance(command, list)
            and command
            and all(isinstance(argument, str) and argument for argument in command)
            and shutil.which(command[0])
        ):
            return command
    except (FileNotFoundError, KeyError, OSError, TypeError, ValueError, json.JSONDecodeError):
        pass

    for candidate in ("google-chrome-stable", "chromium", "firefox"):
        if shutil.which(candidate):
            return [candidate]
    return ["xdg-open", "about:blank"]


def browser_window_classes(command):
    name = Path(command[0]).name if command else ""
    return {
        "google-chrome-stable": ("google-chrome", "google-chrome-stable"),
        "google-chrome": ("google-chrome",),
        "chromium": ("chromium",),
        "firefox": ("firefox",),
        "brave": ("brave-browser", "brave"),
        "brave-browser": ("brave-browser", "brave"),
        "microsoft-edge-stable": ("microsoft-edge", "microsoft-edge-stable"),
    }.get(name, (name.lower(),))


@contextmanager
def exclusive_lock(path, blocking=True):
    path.parent.mkdir(parents=True, exist_ok=True)
    handle = path.open("a+")
    flags = fcntl.LOCK_EX | (0 if blocking else fcntl.LOCK_NB)
    try:
        fcntl.flock(handle.fileno(), flags)
    except BlockingIOError:
        handle.close()
        yield None
        return
    try:
        yield handle
    finally:
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        handle.close()


def write_text_atomic(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(
        prefix=f".{path.name}.", suffix=".tmp", dir=path.parent
    )
    temporary = Path(temporary_name)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as stream:
            stream.write(content)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def command_program(command):
    words = list(command or ())
    if words and Path(words[0]).name == "env":
        words.pop(0)
        while words and (words[0].startswith("-") or "=" in words[0]):
            option = words.pop(0)
            if option in {"-u", "--unset", "-C", "--chdir"} and words:
                words.pop(0)
    while words and "=" in words[0] and not words[0].startswith(("/", "./")):
        words.pop(0)
    return words[0] if words else ""


def command_executable(command):
    program = command_program(command)
    return Path(program).name if program else ""


def caelestia_explorer_command():
    """Read Caelestia's current file manager command on every activation."""
    try:
        payload = json.loads(CAELESTIA_CONFIG.read_text(encoding="utf-8"))
        command = payload["general"]["apps"]["explorer"]
    except (FileNotFoundError, OSError, KeyError, TypeError, json.JSONDecodeError):
        return None
    if isinstance(command, str):
        try:
            command = shlex.split(command)
        except ValueError:
            return None
    if not isinstance(command, list) or not command:
        return None
    command = [str(part) for part in command if str(part)]
    if not command:
        return None
    program = command_program(command)
    executable_path = Path(program).expanduser()
    if not program or (
        shutil.which(program) is None
        and not (executable_path.is_file() and os.access(executable_path, os.X_OK))
    ):
        return None
    return command


def file_manager_command(target):
    command = caelestia_explorer_command()
    if command is None:
        return ["gio", "open", str(target)]
    target = str(target)
    result = []
    inserted = False
    for part in command:
        if part in {"%f", "%F", "%u", "%U"}:
            result.append(target)
            inserted = True
        elif part in {"%d", "%D", "%n", "%N", "%i", "%c", "%k", "%v", "%m"}:
            continue
        else:
            result.append(part)
    if not inserted:
        result.append(target)
    return result


_FILE_MANAGER_PATTERN_CACHE = {}


def file_manager_patterns():
    command = caelestia_explorer_command()
    executable = command_executable(command)
    cache_key = tuple(command or ())
    cached = _FILE_MANAGER_PATTERN_CACHE.get(cache_key)
    if cached is not None:
        return cached

    patterns = list(RUNNING_CLASSES["files"])
    executable_lower = executable.casefold()
    for value in (executable_lower, Path(executable_lower).stem):
        if value and value not in patterns:
            patterns.append(value)

    desktop_ids = []
    if command and Path(command[0]).name in {"gtk-launch", "gio"}:
        desktop_ids.extend(
            part for part in command[1:] if isinstance(part, str) and part.endswith(".desktop")
        )
    for directory in APP_DIRS:
        try:
            entries = tuple(directory.glob("*.desktop"))
        except OSError:
            continue
        for path in entries:
            parser = configparser.ConfigParser(interpolation=None, strict=False)
            try:
                parser.read(path, encoding="utf-8")
                entry = parser["Desktop Entry"]
                words = shlex.split(entry.get("Exec", ""))
            except (OSError, KeyError, ValueError, configparser.Error):
                continue
            if path.name not in desktop_ids and (
                not executable_lower
                or command_executable(words).casefold() != executable_lower
            ):
                continue
            for value in (entry.get("StartupWMClass", ""), path.stem):
                value = value.strip().casefold()
                if value and value not in patterns:
                    patterns.append(value)
    result = tuple(patterns)
    _FILE_MANAGER_PATTERN_CACHE.clear()
    _FILE_MANAGER_PATTERN_CACHE[cache_key] = result
    return result


def valid_desktop_id(value):
    return (
        isinstance(value, str)
        and value.endswith(".desktop")
        and 1 <= len(value) <= 240
        and "/" not in value
        and "\\" not in value
        and "\x00" not in value
    )


def load_pinned_keys():
    with exclusive_lock(PINS_LOCK_FILE):
        try:
            payload = json.loads(PINS_FILE.read_text(encoding="utf-8"))
            raw_items = payload.get("items", []) if isinstance(payload, dict) else []
        except (FileNotFoundError, OSError, json.JSONDecodeError):
            return list(DEFAULT_PINNED_KEYS)

    result = []
    for raw in raw_items if isinstance(raw_items, list) else []:
        key = str(raw)
        if key.startswith("builtin:"):
            valid = key.split(":", 1)[1] in BUILTIN_ITEMS
        elif key.startswith("desktop:"):
            valid = valid_desktop_id(key.split(":", 1)[1])
        else:
            valid = False
        if valid and key not in result:
            result.append(key)
        if len(result) >= MAX_PINNED_ITEMS:
            break
    if "builtin:files" not in result:
        result.insert(0, "builtin:files")
    else:
        result.remove("builtin:files")
        result.insert(0, "builtin:files")
    return result


def save_pinned_keys(keys):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    payload = {"version": 1, "items": list(keys[:MAX_PINNED_ITEMS])}
    with exclusive_lock(PINS_LOCK_FILE):
        write_text_atomic(
            PINS_FILE, json.dumps(payload, ensure_ascii=False, indent=2) + "\n"
        )


def resolve_desktop_entry(app_id):
    """Resolve a dropped ID locally; never trust an external drag's Exec field."""
    if not valid_desktop_id(app_id):
        return None
    path = next((directory / app_id for directory in APP_DIRS if (directory / app_id).is_file()), None)
    if path is None:
        return None
    parser = configparser.ConfigParser(interpolation=None, strict=False)
    try:
        parser.read(path, encoding="utf-8")
        entry = parser["Desktop Entry"]
    except (OSError, KeyError, configparser.Error):
        return None
    if entry.get("Type", "Application") != "Application" or not entry.get("Exec"):
        return None
    if entry.get("NoDisplay", "").lower() in {"1", "true"} and entry.get(
        "OnlyShowIn", ""
    ):
        # Keep normal apps; still allow matching via StartupWMClass below.
        pass
    name = entry.get("Name[zh_CN]", entry.get("Name", path.stem)).strip()
    icon = entry.get("Icon", "application-x-executable").strip()
    command = re.sub(r"\s+%[fFuUdDnNickvm]", "", entry.get("Exec", "")).strip()
    patterns = []
    for value in (entry.get("StartupWMClass", ""), path.stem):
        value = value.strip().lower()
        if len(value) >= 2 and value not in patterns:
            patterns.append(value)
    try:
        words = shlex.split(command)
    except ValueError:
        words = []
    while words and (words[0] == "env" or "=" in words[0]):
        words.pop(0)
    if words:
        executable = Path(words[0]).name.lower()
        if len(executable) >= 2 and executable not in patterns:
            patterns.append(executable)
    return {
        "desktop_id": app_id,
        "name": name or path.stem,
        "icon": icon or "application-x-executable",
        "patterns": tuple(patterns),
    }


def build_desktop_class_index():
    """Map window class / exec stem → desktop_id for running unpinned apps."""
    index = {}
    for directory in APP_DIRS:
        if not directory.is_dir():
            continue
        try:
            entries = list(directory.glob("*.desktop"))
        except OSError:
            continue
        for path in entries:
            app_id = path.name
            entry = resolve_desktop_entry(app_id)
            if entry is None:
                continue
            for pattern in entry["patterns"]:
                index.setdefault(pattern, app_id)
            # Also index the desktop stem and common variants.
            stem = path.stem.lower()
            index.setdefault(stem, app_id)
            index.setdefault(stem.replace("_", "-"), app_id)
            index.setdefault(stem.replace("-", "_"), app_id)
    return index


def desktop_id_for_window_class(wm_class):
    global _DESKTOP_CLASS_INDEX
    value = str(wm_class or "").strip().lower()
    if not value or value in SKIP_RUNNING_CLASSES:
        return None
    if _DESKTOP_CLASS_INDEX is None:
        _DESKTOP_CLASS_INDEX = build_desktop_class_index()
    # Exact match first.
    if value in _DESKTOP_CLASS_INDEX:
        return _DESKTOP_CLASS_INDEX[value]
    # Chromium-style "Google-chrome" / "org.gnome.Nautilus"
    compact = value.replace(" ", "").replace("_", "-")
    if compact in _DESKTOP_CLASS_INDEX:
        return _DESKTOP_CLASS_INDEX[compact]
    # Last segment after '.' (org.gnome.Nautilus → nautilus)
    if "." in value:
        tail = value.rsplit(".", 1)[-1]
        if tail in _DESKTOP_CLASS_INDEX:
            return _DESKTOP_CLASS_INDEX[tail]
    return None


def find_layer_by_namespace(namespace):
    """Return (layer_dict, monitor_dict) for a Hyprland layer namespace, or (None, None)."""
    try:
        layers = json.loads(
            subprocess.check_output(
                ["hyprctl", "layers", "-j"],
                text=True,
                timeout=0.8,
            )
        )
        monitors = hypr_json("monitors") or []
    except (OSError, ValueError, subprocess.SubprocessError, json.JSONDecodeError):
        return None, None
    if not isinstance(layers, dict):
        return None, None
    mon_by_name = {
        str(m.get("name", "")): m for m in monitors if isinstance(m, dict)
    }
    for mon_name, monitor_layers in layers.items():
        if not isinstance(monitor_layers, dict):
            continue
        levels = monitor_layers.get("levels", monitor_layers)
        if not isinstance(levels, dict):
            continue
        for level in levels.values():
            if not isinstance(level, list):
                continue
            for layer in level:
                if layer.get("namespace") == namespace:
                    return layer, mon_by_name.get(str(mon_name))
    return None, None


def pin_desktop_at_screen_x(desktop_id, screen_x):
    if resolve_desktop_entry(desktop_id) is None:
        return False
    dock_layer, _monitor = find_layer_by_namespace("villode-dock")
    if dock_layer is None:
        return False

    keys = load_pinned_keys()
    key = (
        f"builtin:{BUILTIN_DESKTOP_IDS[desktop_id.lower()]}"
        if desktop_id.lower() in BUILTIN_DESKTOP_IDS
        else f"desktop:{desktop_id}"
    )
    if key == "builtin:files":
        return True

    surface_x = float(dock_layer.get("x", 0))
    surface_width = float(dock_layer.get("w", 600))
    local_x = float(screen_x) - surface_x
    panel_width = (len(keys) + len(PLACE_ITEMS)) * 61 + 17 + 24
    cursor = (surface_width - panel_width) / 2.0 + 12
    insertion_index = len(keys)
    for index in range(len(keys)):
        if local_x < cursor + 61 / 2.0:
            insertion_index = max(1, index)
            break
        cursor += 61

    if key in keys:
        old_index = keys.index(key)
        keys.pop(old_index)
        if insertion_index > old_index:
            insertion_index -= 1
    elif len(keys) >= MAX_PINNED_ITEMS:
        return False
    keys.insert(max(1, min(insertion_index, len(keys))), key)
    save_pinned_keys(keys)

    pid = read_pid()
    if process_alive(pid):
        try:
            os.kill(pid, signal.SIGHUP)
        except OSError:
            pass
    return True


def read_pid():
    try:
        return int(PID_FILE.read_text().strip())
    except (FileNotFoundError, ValueError, OSError):
        return None


def acquire_instance_lock():
    PID_LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    handle = PID_LOCK_FILE.open("a+")
    try:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        handle.close()
        return None
    return handle


def release_instance_lock(handle):
    if handle is None:
        return
    fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    handle.close()


def process_alive(pid):
    if not pid:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

    try:
        cmdline = Path(f"/proc/{pid}/cmdline").read_text(errors="ignore")
    except (FileNotFoundError, OSError):
        return False
    return "villode-dock" in cmdline


def _stop_running():
    pid = read_pid()
    if not process_alive(pid):
        PID_FILE.unlink(missing_ok=True)
        return False

    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        PID_FILE.unlink(missing_ok=True)
        return False

    for _ in range(40):
        if not process_alive(pid):
            PID_FILE.unlink(missing_ok=True)
            return True
        time.sleep(0.05)

    try:
        os.kill(pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    PID_FILE.unlink(missing_ok=True)
    return True


def stop_running():
    with exclusive_lock(OPERATION_LOCK_FILE):
        return _stop_running()


def _start_daemon():
    pid = read_pid()
    if process_alive(pid):
        return pid

    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    process = subprocess.Popen(
        [sys.executable, str(SCRIPT), "--run"],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True,
    )
    write_text_atomic(PID_FILE, f"{process.pid}\n")
    return process.pid


def start_daemon():
    with exclusive_lock(OPERATION_LOCK_FILE):
        return _start_daemon()


def restart_daemon():
    with exclusive_lock(OPERATION_LOCK_FILE):
        _stop_running()
        return _start_daemon()


def toggle_daemon():
    with exclusive_lock(OPERATION_LOCK_FILE):
        if process_alive(read_pid()):
            _stop_running()
            return None
        return _start_daemon()


def spawn_command(command):
    """Launch on the currently focused Hyprland workspace.

    Dock is a long-lived daemon. Direct Popen inherits the daemon's initial
    workspace for Hyprland's initial_workspace_tracking, so apps opened from an
    empty workspace can land on workspace 1. Prefer hyprctl dispatch exec.
    """
    if not command:
        return False
    argv = [str(part) for part in command]
    try:
        result = subprocess.run(
            ["hyprctl", "dispatch", "exec", "--", *argv],
            check=False,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=3,
        )
        if result.returncode == 0:
            return True
    except (OSError, subprocess.TimeoutExpired):
        pass
    try:
        subprocess.Popen(
            argv,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
            close_fds=True,
        )
    except OSError:
        return False
    return True


def hypr_json(command, timeout=0.7):
    try:
        result = subprocess.run(
            ["hyprctl", command, "-j"],
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        if result.returncode != 0:
            return None
        return json.loads(result.stdout)
    except (OSError, subprocess.TimeoutExpired, json.JSONDecodeError):
        return None


def hypr_clients():
    clients = hypr_json("clients")
    return clients if isinstance(clients, list) else None


def monitor_logical_geometry(monitor):
    try:
        scale = max(0.1, float(monitor.get("scale", 1.0)))
        width = float(monitor["width"]) / scale
        height = float(monitor["height"]) / scale
        if int(monitor.get("transform", 0)) % 2:
            width, height = height, width
        return (
            float(monitor["x"]),
            float(monitor["y"]),
            width,
            height,
        )
    except (KeyError, TypeError, ValueError):
        return None


def rectangle_overlap(first, second):
    left = max(first[0], second[0])
    top = max(first[1], second[1])
    right = min(first[0] + first[2], second[0] + second[2])
    bottom = min(first[1] + first[3], second[1] + second[3])
    return max(0.0, right - left) * max(0.0, bottom - top)


def hypr_monitor_fullscreen(monitor_geometry, clients=None):
    """Return fullscreen state for the monitor carrying this Dock, or None."""
    monitors = hypr_json("monitors")
    if not isinstance(monitors, list) or not monitors:
        return None

    monitor = None
    if monitor_geometry is not None:
        candidates = [
            (rectangle_overlap(monitor_geometry, geometry), item)
            for item in monitors
            if (geometry := monitor_logical_geometry(item)) is not None
        ]
        if candidates:
            overlap, candidate = max(candidates, key=lambda pair: pair[0])
            if overlap > 0:
                monitor = candidate
    if monitor is None and monitor_geometry is None:
        monitor = next((item for item in monitors if item.get("focused")), monitors[0])
    if monitor is None:
        return None

    active = monitor.get("specialWorkspace")
    if not isinstance(active, dict) or not active.get("id"):
        active = monitor.get("activeWorkspace")
    if not isinstance(active, dict):
        return None
    workspace_id = active.get("id")
    workspace_name = str(active.get("name", ""))

    workspaces = hypr_json("workspaces")
    if isinstance(workspaces, list):
        workspace = next(
            (
                item
                for item in workspaces
                if item.get("id") == workspace_id
                or (workspace_name and str(item.get("name", "")) == workspace_name)
            ),
            None,
        )
        if isinstance(workspace, dict) and "hasfullscreen" in workspace:
            return bool(workspace.get("hasfullscreen"))

    if isinstance(clients, list):
        for client in clients:
            workspace = client.get("workspace", {})
            same_workspace = isinstance(workspace, dict) and (
                workspace.get("id") == workspace_id
                or (workspace_name and str(workspace.get("name", "")) == workspace_name)
            )
            if same_workspace and client.get("fullscreen") not in (0, False, None):
                return True
        return False
    return None


def hypr_reserved_bottom():
    """Return the reservation that existed before this Dock was mapped."""
    try:
        result = subprocess.run(
            ["hyprctl", "monitors", "-j"],
            check=False,
            capture_output=True,
            text=True,
            timeout=0.7,
        )
        monitors = json.loads(result.stdout) if result.returncode == 0 else []
        if not isinstance(monitors, list) or not monitors:
            return 0
        monitor = next((item for item in monitors if item.get("focused")), monitors[0])
        reserved = monitor.get("reserved", [])
        if isinstance(reserved, list) and len(reserved) >= 4:
            return max(0, int(reserved[3]))
    except (OSError, ValueError, subprocess.TimeoutExpired, json.JSONDecodeError):
        pass
    return 0


def hypr_focused_monitor_geometry():
    monitors = hypr_json("monitors")
    if not isinstance(monitors, list) or not monitors:
        return None
    monitor = next((item for item in monitors if item.get("focused")), monitors[0])
    return monitor_logical_geometry(monitor)


def run_dock():
    try:
        import cairo
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("GdkPixbuf", "2.0")
        gi.require_version("Gio", "2.0")
        gi.require_version("Gtk", "3.0")
        gi.require_version("GtkLayerShell", "0.1")
        gi.require_version("Pango", "1.0")
        gi.require_version("PangoCairo", "1.0")
        from gi.repository import (
            Gdk,
            GdkPixbuf,
            Gio,
            GLib,
            Gtk,
            GtkLayerShell,
            Pango,
            PangoCairo,
        )
    except (ImportError, ValueError) as error:
        print(f"villode-dock: 缺少 GTK 运行组件：{error}", file=sys.stderr)
        return 1

    # Logical-pixel geometry.  The tall transparent surface is only an animation
    # canvas; the exclusive zone below starts at PANEL_TOP, not at the canvas top.
    SURFACE_WIDTH = 600
    WINDOW_HEIGHT = 128
    PANEL_TOP = 50
    PANEL_BOTTOM = 116
    PANEL_RADIUS = 19
    PANEL_PADDING = 12
    BASE_ICON_SIZE = 48
    BASE_SLOT_WIDTH = 61
    ICON_BOTTOM = 109
    DOT_Y = 112.5
    SEPARATOR_GAP = 17
    EXTERNAL_DROP_GAP = 48
    EXTERNAL_INDEX_TRANSITION = 0.12
    EXTERNAL_INDEX_HYSTERESIS = 7.0
    LAYOUT_SPRING = 235.0
    LAYOUT_DAMPING = 20.0
    REMOVE_ARM_Y = PANEL_TOP - 18.0
    REMOVE_DISARM_Y = PANEL_TOP - 7.0
    MAX_SCALE = 1.50
    WAVE_RADIUS = 145.0
    TOOLTIP_DELAY = 0.28


    def rounded_rectangle(cr, x, y, width, height, radius):
        radius = max(0.0, min(radius, width / 2.0, height / 2.0))
        cr.new_sub_path()
        cr.arc(x + width - radius, y + radius, radius, -math.pi / 2, 0)
        cr.arc(x + width - radius, y + height - radius, radius, 0, math.pi / 2)
        cr.arc(x + radius, y + height - radius, radius, math.pi / 2, math.pi)
        cr.arc(x + radius, y + radius, radius, math.pi, 3 * math.pi / 2)
        cr.close_path()


    def load_glass_theme():
        settings = Gtk.Settings.get_default()
        theme_name = (
            settings.get_property("gtk-theme-name").lower() if settings is not None else ""
        )
        dark = "dark" in theme_name
        fallback = {
            "surface": (0.11, 0.13, 0.16) if dark else (0.78, 0.84, 0.91),
            "text": (0.91, 0.93, 0.97) if dark else (0.10, 0.12, 0.15),
            "muted": (0.68, 0.71, 0.76) if dark else (0.29, 0.32, 0.38),
            "outline": (0.32, 0.35, 0.40) if dark else (0.57, 0.62, 0.68),
            "primary": (0.66, 0.79, 0.91) if dark else (0.23, 0.39, 0.58),
            "alpha": 0.34,
        }
        palette = {}
        try:
            palettes = sorted(
                CAELESTIA_SCHEMES_DIR.rglob("*.json"),
                key=lambda path: path.stat().st_mtime,
                reverse=True,
            )
            for path in palettes:
                data = json.loads(path.read_text())
                if isinstance(data, dict) and "surface" in data and "onSurface" in data:
                    palette = data
                    break
        except (OSError, ValueError, json.JSONDecodeError):
            pass

        try:
            transparency = json.loads(CAELESTIA_CONFIG.read_text()).get(
                "appearance", {}
            ).get("transparency", {})
            alpha = float(transparency.get("layers", fallback["alpha"]))
            if not transparency.get("enabled", True):
                alpha = 0.94
            fallback["alpha"] = max(0.12, min(0.94, alpha))
        except (OSError, ValueError, TypeError, json.JSONDecodeError):
            pass

        return {
            "surface": color_from_hex(
                palette.get("surfaceContainerHigh"), fallback["surface"]
            ),
            "text": color_from_hex(palette.get("onSurface"), fallback["text"]),
            "muted": color_from_hex(
                palette.get("onSurfaceVariant"), fallback["muted"]
            ),
            "outline": color_from_hex(
                palette.get("outlineVariant"), fallback["outline"]
            ),
            "primary": color_from_hex(palette.get("primary"), fallback["primary"]),
            "alpha": fallback["alpha"],
        }


    def create_dismiss_layer(gdk_monitor, callback):
        """Fullscreen click-catcher. Near-invisible alpha so Wayland still hits it."""
        window = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
        window.set_app_paintable(True)
        window.set_decorated(False)
        window.set_resizable(False)
        window.set_accept_focus(False)
        window.set_skip_taskbar_hint(True)
        window.set_skip_pager_hint(True)
        visual = window.get_screen().get_rgba_visual()
        if visual is not None:
            window.set_visual(visual)
        GtkLayerShell.init_for_window(window)
        GtkLayerShell.set_namespace(window, "villode-dock-menu-dismiss")
        # Must sit above menu (order 60) so it catches clicks outside the menu
        # while the menu still receives clicks inside its own bounds.
        GtkLayerShell.set_layer(window, GtkLayerShell.Layer.TOP)
        GtkLayerShell.set_keyboard_mode(window, GtkLayerShell.KeyboardMode.NONE)
        GtkLayerShell.set_exclusive_zone(window, -1)
        for edge in (
            GtkLayerShell.Edge.TOP,
            GtkLayerShell.Edge.BOTTOM,
            GtkLayerShell.Edge.LEFT,
            GtkLayerShell.Edge.RIGHT,
        ):
            GtkLayerShell.set_anchor(window, edge, True)
        if gdk_monitor is not None:
            try:
                GtkLayerShell.set_monitor(window, gdk_monitor)
            except Exception:
                pass

        area = Gtk.EventBox()
        area.set_app_paintable(True)
        area.set_visible_window(True)
        area.set_above_child(True)
        area.set_size_request(1, 1)
        area.add_events(
            Gdk.EventMask.BUTTON_PRESS_MASK
            | Gdk.EventMask.BUTTON_RELEASE_MASK
            | Gdk.EventMask.POINTER_MOTION_MASK
        )

        def clear(_widget, cr):
            # Completely transparent surfaces often receive no input on Wayland;
            # keep a tiny alpha so hit-testing works (still look invisible).
            cr.set_operator(cairo.OPERATOR_SOURCE)
            cr.set_source_rgba(0.0, 0.0, 0.0, 0.01)
            cr.paint()
            return False

        area.connect("draw", clear)

        def dismiss(*_args):
            GLib.idle_add(callback)
            return True

        area.connect("button-press-event", dismiss)
        area.connect("button-release-event", dismiss)
        window.connect("button-press-event", dismiss)
        window.connect("button-release-event", dismiss)
        window.add(area)
        window.show_all()
        # Raise after map so we sit above the dock but under the menu (order rules).
        GLib.idle_add(window.present)
        return window


    class GlassContextMenu:
        """Compact glass menu with a transparent outside-click dismiss layer."""

        ROW_H = 36
        PAD_X = 16
        PAD_Y = 10
        RADIUS = 14
        MIN_WIDTH = 176
        _active = None

        def __init__(self, parent, entries, screen_x, screen_y):
            self.parent = parent
            self.entries = list(entries)
            self.screen_x = float(screen_x)
            self.screen_y = float(screen_y)
            self.hover = None
            self.window = None
            self.area = None
            self.width = self.MIN_WIDTH
            self.height = self.PAD_Y * 2
            self.dismiss = None
            self.theme = load_glass_theme()

        @classmethod
        def close_active(cls):
            if cls._active is not None:
                cls._active.close()

        def _gdk_monitor_for(self, hypr_mon):
            display = Gdk.Display.get_default()
            if display is None:
                return None
            if hypr_mon is None:
                return display.get_primary_monitor()
            mon_x = float(hypr_mon.get("x", 0))
            mon_y = float(hypr_mon.get("y", 0))
            mon_w = float(hypr_mon.get("width", 0))
            for i in range(display.get_n_monitors()):
                m = display.get_monitor(i)
                g = m.get_geometry()
                if abs(g.x - mon_x) < 2 and abs(g.y - mon_y) < 2 and abs(g.width - mon_w) < 2:
                    return m
            return display.get_primary_monitor()

        def popup(self):
            GlassContextMenu.close_active()
            if not self.entries:
                return

            tmp = cairo.ImageSurface(cairo.FORMAT_ARGB32, 1, 1)
            cr = cairo.Context(tmp)
            layout = PangoCairo.create_layout(cr)
            layout.set_font_description(Pango.FontDescription("Sans Medium 11"))
            max_tw = 0
            for entry in self.entries:
                if entry.get("separator"):
                    continue
                layout.set_text(entry.get("label", ""), -1)
                tw, _th = layout.get_pixel_size()
                max_tw = max(max_tw, tw)
            self.width = max(self.MIN_WIDTH, int(max_tw + self.PAD_X * 2 + 8))
            h = self.PAD_Y * 2
            for entry in self.entries:
                h += 9 if entry.get("separator") else self.ROW_H
            self.height = int(h)

            _dock_layer, hypr_mon = find_layer_by_namespace("villode-dock")
            if hypr_mon is not None:
                mon_x = float(hypr_mon.get("x", 0))
                mon_y = float(hypr_mon.get("y", 0))
                mon_w = float(hypr_mon.get("width", 1920))
                mon_h = float(hypr_mon.get("height", 1080))
            else:
                mon_x = mon_y = 0.0
                mon_w, mon_h = 1920.0, 1080.0

            left = self.screen_x - mon_x - self.width / 2.0
            top = self.screen_y - mon_y - self.height
            left = max(8.0, min(mon_w - self.width - 8.0, left))
            top = max(8.0, min(mon_h - self.height - 8.0, top))
            margin_left = int(round(left))
            margin_top = int(round(top))
            gdk_monitor = self._gdk_monitor_for(hypr_mon)
            self.theme = load_glass_theme()
            self.dismiss = create_dismiss_layer(gdk_monitor, self.close)

            window = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
            window.set_app_paintable(True)
            window.set_decorated(False)
            window.set_resizable(False)
            window.set_accept_focus(True)
            window.set_skip_taskbar_hint(True)
            window.set_skip_pager_hint(True)
            visual = window.get_screen().get_rgba_visual()
            if visual is not None:
                window.set_visual(visual)
            GtkLayerShell.init_for_window(window)
            GtkLayerShell.set_namespace(window, "villode-dock-menu")
            GtkLayerShell.set_layer(window, GtkLayerShell.Layer.OVERLAY)
            # Exclusive keyboard so Esc always reaches us.
            GtkLayerShell.set_keyboard_mode(
                window, GtkLayerShell.KeyboardMode.ON_DEMAND
            )
            GtkLayerShell.set_exclusive_zone(window, -1)
            GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.TOP, True)
            GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.LEFT, True)
            GtkLayerShell.set_margin(window, GtkLayerShell.Edge.TOP, max(0, margin_top))
            GtkLayerShell.set_margin(window, GtkLayerShell.Edge.LEFT, max(0, margin_left))
            if gdk_monitor is not None:
                try:
                    GtkLayerShell.set_monitor(window, gdk_monitor)
                except Exception:
                    pass

            area = Gtk.DrawingArea()
            area.set_size_request(self.width, self.height)
            area.set_app_paintable(True)
            area.set_can_focus(True)
            # add_events merges; set_events replaces and can drop button events on some GTK builds.
            area.add_events(
                Gdk.EventMask.POINTER_MOTION_MASK
                | Gdk.EventMask.BUTTON_PRESS_MASK
                | Gdk.EventMask.BUTTON_RELEASE_MASK
                | Gdk.EventMask.KEY_PRESS_MASK
                | Gdk.EventMask.ENTER_NOTIFY_MASK
                | Gdk.EventMask.LEAVE_NOTIFY_MASK
            )
            area.connect("draw", self.on_draw)
            area.connect("motion-notify-event", self.on_motion)
            area.connect("leave-notify-event", self.on_leave)
            area.connect("button-press-event", self.on_button_press)
            area.connect("button-release-event", self.on_button_release)
            area.connect("key-press-event", self.on_key)
            window.connect("key-press-event", self.on_key)
            window.connect("button-press-event", self.on_button_press)
            window.connect("button-release-event", self.on_button_release)
            window.connect("destroy", lambda *_: self._cleared())
            window.add(area)

            self.window = window
            self.area = area
            GlassContextMenu._active = self
            window.show_all()
            window.present()
            GLib.idle_add(area.grab_focus)

        def _cleared(self):
            if GlassContextMenu._active is self:
                GlassContextMenu._active = None
            self.window = None
            self.area = None
            self.close_dismiss()

        def close_dismiss(self):
            dismiss = self.dismiss
            self.dismiss = None
            if dismiss is not None:
                try:
                    dismiss.destroy()
                except Exception:
                    pass

        def close(self):
            win = self.window
            self.window = None
            self.area = None
            if GlassContextMenu._active is self:
                GlassContextMenu._active = None
            self.close_dismiss()
            if win is not None:
                try:
                    win.destroy()
                except Exception:
                    pass

        def row_at(self, x, y):
            y0 = self.PAD_Y
            for i, entry in enumerate(self.entries):
                if entry.get("separator"):
                    y0 += 9
                    continue
                y1 = y0 + self.ROW_H
                if y0 <= y < y1 and 0 <= x <= self.width:
                    if entry.get("sensitive", True) is False:
                        return None
                    return i
                y0 = y1
            return None

        def on_motion(self, _widget, event):
            idx = self.row_at(event.x, event.y)
            if idx != self.hover:
                self.hover = idx
                if self.area is not None:
                    self.area.queue_draw()
            return True

        def on_leave(self, _widget, _event):
            if self.hover is not None:
                self.hover = None
                if self.area is not None:
                    self.area.queue_draw()
            return True

        def _activate_at(self, x, y):
            idx = self.row_at(x, y)
            entry = self.entries[idx] if idx is not None else None
            self.close()
            if entry is not None:
                callback = entry.get("callback")
                if callable(callback) and entry.get("sensitive", True):
                    GLib.idle_add(callback)
            return True

        def on_button_press(self, _widget, event):
            if event.button in (Gdk.BUTTON_PRIMARY, Gdk.BUTTON_SECONDARY):
                return self._activate_at(event.x, event.y)
            self.close()
            return True

        def on_button_release(self, _widget, event):
            # Some GTK/Wayland builds only deliver release reliably.
            if event.button == Gdk.BUTTON_PRIMARY:
                return self._activate_at(event.x, event.y)
            return True

        def on_key(self, _widget, event):
            if event.keyval == Gdk.KEY_Escape:
                self.close()
                return True
            return False

        def on_draw(self, _widget, cr):
            cr.set_operator(cairo.OPERATOR_SOURCE)
            cr.set_source_rgba(0.0, 0.0, 0.0, 0.0)
            cr.paint()
            cr.set_operator(cairo.OPERATOR_OVER)

            rounded_rectangle(
                cr, 0.5, 0.5, self.width - 1.0, self.height - 1.0, self.RADIUS
            )
            cr.set_source_rgba(*self.theme["surface"], self.theme["alpha"])
            cr.fill_preserve()
            cr.clip()

            sheen = cairo.LinearGradient(0, 0, 0, self.height)
            sheen.add_color_stop_rgba(0.0, *self.theme["text"], 0.18)
            sheen.add_color_stop_rgba(0.45, *self.theme["text"], 0.06)
            sheen.add_color_stop_rgba(1.0, *self.theme["primary"], 0.05)
            cr.set_source(sheen)
            cr.paint()
            cr.reset_clip()

            cr.new_path()
            rounded_rectangle(
                cr, 0.75, 0.75, self.width - 1.5, self.height - 1.5, self.RADIUS - 0.5
            )
            cr.set_line_width(1.0)
            cr.set_source_rgba(*self.theme["outline"], 0.68)
            cr.stroke()

            layout = PangoCairo.create_layout(cr)
            layout.set_font_description(Pango.FontDescription("Sans Medium 11"))
            y0 = self.PAD_Y
            for i, entry in enumerate(self.entries):
                if entry.get("separator"):
                    cy = y0 + 4.0
                    cr.set_source_rgba(*self.theme["outline"], 0.46)
                    cr.set_line_width(1.0)
                    cr.move_to(self.PAD_X, cy)
                    cr.line_to(self.width - self.PAD_X, cy)
                    cr.stroke()
                    y0 += 9
                    continue

                sensitive = entry.get("sensitive", True)
                if i == self.hover and sensitive:
                    rounded_rectangle(
                        cr, 6, y0 + 2, self.width - 12, self.ROW_H - 4, 8
                    )
                    cr.set_source_rgba(*self.theme["primary"], 0.22)
                    cr.fill()

                layout.set_text(entry.get("label", ""), -1)
                _tw, th = layout.get_pixel_size()
                if sensitive:
                    cr.set_source_rgba(*self.theme["text"], 0.96)
                else:
                    cr.set_source_rgba(*self.theme["muted"], 0.52)
                cr.move_to(self.PAD_X, y0 + (self.ROW_H - th) / 2.0)
                PangoCairo.show_layout(cr, layout)
                y0 += self.ROW_H
            return False


    class GlassAboutDialog:
        """Centered glass about panel (layer-shell + Hyprland blur)."""

        WIDTH = 420
        HEIGHT = 340
        RADIUS = 22
        _active = None

        def __init__(self, parent):
            self.parent = parent
            self.window = None
            self.dismiss = None
            self.theme = load_glass_theme()

        @classmethod
        def close_active(cls):
            if cls._active is not None:
                cls._active.close()

        def popup(self):
            GlassAboutDialog.close_active()
            GlassContextMenu.close_active()

            dock_layer, hypr_mon = find_layer_by_namespace("villode-dock")
            if hypr_mon is not None:
                mon_x = float(hypr_mon.get("x", 0))
                mon_y = float(hypr_mon.get("y", 0))
                mon_w = float(hypr_mon.get("width", 1920))
                mon_h = float(hypr_mon.get("height", 1080))
            else:
                mon_x = mon_y = 0.0
                mon_w, mon_h = 1920.0, 1080.0

            margin_left = int(round((mon_w - self.WIDTH) / 2.0))
            margin_top = int(round((mon_h - self.HEIGHT) / 2.0))

            gdk_monitor = None
            display = Gdk.Display.get_default()
            if display is not None:
                if hypr_mon is not None:
                    for i in range(display.get_n_monitors()):
                        m = display.get_monitor(i)
                        g = m.get_geometry()
                        if abs(g.x - mon_x) < 2 and abs(g.y - mon_y) < 2:
                            gdk_monitor = m
                            break
                if gdk_monitor is None:
                    gdk_monitor = display.get_primary_monitor()
            self.theme = load_glass_theme()

            def make_layer(namespace, keyboard=False):
                win = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
                win.set_app_paintable(True)
                win.set_decorated(False)
                win.set_resizable(False)
                win.set_accept_focus(keyboard)
                win.set_skip_taskbar_hint(True)
                win.set_skip_pager_hint(True)
                visual = win.get_screen().get_rgba_visual()
                if visual is not None:
                    win.set_visual(visual)
                GtkLayerShell.init_for_window(win)
                GtkLayerShell.set_namespace(win, namespace)
                GtkLayerShell.set_layer(win, GtkLayerShell.Layer.OVERLAY)
                GtkLayerShell.set_keyboard_mode(
                    win,
                    GtkLayerShell.KeyboardMode.ON_DEMAND
                    if keyboard
                    else GtkLayerShell.KeyboardMode.NONE,
                )
                GtkLayerShell.set_exclusive_zone(win, -1)
                if gdk_monitor is not None:
                    try:
                        GtkLayerShell.set_monitor(win, gdk_monitor)
                    except Exception:
                        pass
                return win

            self.dismiss = create_dismiss_layer(gdk_monitor, self.close)
            window = make_layer("villode-dock-menu", keyboard=True)
            GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.TOP, True)
            GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.LEFT, True)
            GtkLayerShell.set_margin(window, GtkLayerShell.Edge.TOP, max(0, margin_top))
            GtkLayerShell.set_margin(window, GtkLayerShell.Edge.LEFT, max(0, margin_left))
            try:
                GtkLayerShell.set_keyboard_mode(
                    window, GtkLayerShell.KeyboardMode.ON_DEMAND
                )
            except Exception:
                pass

            # Glass backdrop drawn behind content
            backdrop = Gtk.DrawingArea()
            backdrop.set_size_request(self.WIDTH, self.HEIGHT)
            backdrop.connect("draw", self.on_draw_backdrop)

            overlay = Gtk.Overlay()
            overlay.set_size_request(self.WIDTH, self.HEIGHT)
            overlay.add(backdrop)

            page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
            page.set_margin_start(34)
            page.set_margin_end(34)
            page.set_margin_top(28)
            page.set_margin_bottom(24)
            page.set_halign(Gtk.Align.CENTER)
            page.set_valign(Gtk.Align.CENTER)

            icon = Gtk.Image.new_from_icon_name(
                "user-desktop-symbolic", Gtk.IconSize.DIALOG
            )
            icon.set_pixel_size(62)
            icon.set_margin_bottom(14)
            page.pack_start(icon, False, False, 0)

            name = Gtk.Label()
            name.set_markup(
                "<span size='xx-large' weight='bold' foreground='{}'>"
                "Villode Dock</span>".format(hex_from_color(self.theme["text"]))
            )
            name.set_justify(Gtk.Justification.CENTER)
            page.pack_start(name, False, False, 0)

            summary = Gtk.Label()
            summary.set_markup(
                "<span foreground='{}'>为 Hyprland 与 Wayland 设计的桌面 Dock</span>".format(
                    hex_from_color(self.theme["text"])
                )
            )
            summary.set_margin_top(5)
            summary.set_margin_bottom(18)
            page.pack_start(summary, False, False, 0)

            details = Gtk.Label()
            details.set_markup(
                "<span foreground='{}'>"
                "GTK 3  ·  GtkLayerShell  ·  实时合成器模糊</span>".format(
                    hex_from_color(self.theme["text"])
                )
            )
            details.set_margin_bottom(14)
            page.pack_start(details, False, False, 0)

            project = Gtk.Label()
            project.set_markup(
                "<a href='https://github.com/u0n0u/villode-dock'>"
                "GitHub 项目主页</a>"
            )
            project.connect(
                "activate-link",
                lambda _label, uri: spawn_command(["xdg-open", uri]),
            )
            page.pack_start(project, False, False, 0)

            credits = Gtk.Label()
            credits.set_markup(
                "<span foreground='{}' size='small'>"
                "部分图标来自 macOSicons.com 及相应作者"
                "  ·  <a href='villode-credits://icons'>完整署名</a>"
                "</span>".format(hex_from_color(self.theme["muted"]))
            )
            credits.set_margin_top(18)
            credits.set_justify(Gtk.Justification.CENTER)

            def open_credits(_label, uri):
                if uri == "villode-credits://icons":
                    spawn_command(["xdg-open", str(ICON_CREDITS)])
                    return True
                return False

            credits.connect("activate-link", open_credits)
            page.pack_start(credits, False, False, 0)

            close_btn = Gtk.Button.new_with_label("好")
            close_btn.set_margin_top(22)
            close_btn.set_halign(Gtk.Align.CENTER)
            close_btn.connect("clicked", lambda *_: self.close())
            page.pack_start(close_btn, False, False, 0)

            overlay.add_overlay(page)
            window.add(overlay)
            window.connect("key-press-event", self.on_key)
            window.connect("destroy", lambda *_: self._cleared())

            self.window = window
            # Keep self.dismiss from create_dismiss_layer above — do NOT clear it
            # here or the full-screen click-catcher leaks and freezes input.
            GlassAboutDialog._active = self
            window.show_all()
            window.present()

        def on_draw_backdrop(self, _widget, cr):
            cr.set_operator(cairo.OPERATOR_SOURCE)
            cr.set_source_rgba(0, 0, 0, 0)
            cr.paint()
            cr.set_operator(cairo.OPERATOR_OVER)
            rounded_rectangle(
                cr, 0.5, 0.5, self.WIDTH - 1.0, self.HEIGHT - 1.0, self.RADIUS
            )
            cr.set_source_rgba(*self.theme["surface"], self.theme["alpha"])
            cr.fill_preserve()
            cr.clip()
            sheen = cairo.LinearGradient(0, 0, 0, self.HEIGHT)
            sheen.add_color_stop_rgba(0.0, *self.theme["text"], 0.18)
            sheen.add_color_stop_rgba(0.45, *self.theme["text"], 0.06)
            sheen.add_color_stop_rgba(1.0, *self.theme["primary"], 0.05)
            cr.set_source(sheen)
            cr.paint()
            cr.reset_clip()
            cr.new_path()
            rounded_rectangle(
                cr, 0.75, 0.75, self.WIDTH - 1.5, self.HEIGHT - 1.5, self.RADIUS - 0.5
            )
            cr.set_line_width(1.0)
            cr.set_source_rgba(*self.theme["outline"], 0.68)
            cr.stroke()
            return False

        def on_key(self, _widget, event):
            if event.keyval == Gdk.KEY_Escape:
                self.close()
                return True
            return False

        def _cleared(self):
            if GlassAboutDialog._active is self:
                GlassAboutDialog._active = None
            self.window = None
            self.close_dismiss()

        def close_dismiss(self):
            dismiss = self.dismiss
            self.dismiss = None
            if dismiss is not None:
                try:
                    dismiss.destroy()
                except Exception:
                    pass

        def close(self):
            win = self.window
            self.window = None
            if GlassAboutDialog._active is self:
                GlassAboutDialog._active = None
            self.close_dismiss()
            if win is not None:
                try:
                    win.destroy()
                except Exception:
                    pass

    BOUNCE_DURATION = 0.60
    MIN_ANIMATION_FRAME_US = 12_000  # 72 fps on this 144 Hz panel; idle is zero fps.
    EXCLUSIVE_ZONE = WINDOW_HEIGHT - PANEL_TOP

    class DockScene(Gtk.DrawingArea):
        def __init__(self, host_window, reserve_window=None, edge_window=None):
            super().__init__()
            self.host_window = host_window
            self.reserve_window = reserve_window
            self.edge_window = edge_window
            self.fullscreen_hidden = False
            self.fullscreen_revealed = False
            self.fullscreen_hide_id = None
            self.monitor_geometry = None
            self.set_can_focus(False)
            self.add_events(
                Gdk.EventMask.POINTER_MOTION_MASK
                | Gdk.EventMask.ENTER_NOTIFY_MASK
                | Gdk.EventMask.LEAVE_NOTIFY_MASK
                | Gdk.EventMask.BUTTON_PRESS_MASK
                | Gdk.EventMask.BUTTON_RELEASE_MASK
            )

            self.icon_theme = Gtk.IconTheme.get_default()
            self.items = []
            self.pinned_keys = load_pinned_keys()
            self.group_break = 0
            self.surface_width = SURFACE_WIDTH
            self.pointer_inside = False
            self.pointer_x = self.surface_width / 2.0
            self.pointer_y = WINDOW_HEIGHT
            self.hovered = None
            self.hover_since = 0.0
            self.pressed = None
            self.press_position = None
            self.tick_id = None
            self.last_frame_us = None
            self.last_input_rects = None
            self.clients = []
            self.trash_full = False
            self.refresh_in_flight = False
            self.refresh_pending = False
            self.external_drag_active = False
            self.external_drop_index = None
            self.external_previous_drop_index = None
            self.external_index_transition_start = None
            self.external_gap = 0.0
            self.external_gap_target = 0.0
            self.external_gap_velocity = 0.0
            self.pending_drop_index = None
            self.internal_drag_active = False
            self.internal_drop_index = None
            self.internal_remove_armed = False
            self.rebuild_items(resize=False)
            self.set_size_request(self.surface_width, WINDOW_HEIGHT)

            self.connect("draw", self.on_draw)
            self.connect("motion-notify-event", self.on_motion)
            self.connect("enter-notify-event", self.on_enter)
            self.connect("leave-notify-event", self.on_leave)
            self.connect("button-press-event", self.on_button_press)
            self.connect("button-release-event", self.on_button_release)
            targets = [
                Gtk.TargetEntry.new(
                    DOCK_APP_MIME, Gtk.TargetFlags.OTHER_APP, 0
                ),
                Gtk.TargetEntry.new(
                    "text/uri-list", Gtk.TargetFlags.OTHER_APP, 1
                ),
            ]
            self.drag_dest_set(
                Gtk.DestDefaults(0), targets, Gdk.DragAction.COPY
            )
            self.drag_dest_set_track_motion(True)
            self.connect("drag-motion", self.on_drag_motion)
            self.connect("drag-leave", self.on_drag_leave)
            self.connect("drag-drop", self.on_drag_drop)
            self.connect("drag-data-received", self.on_drag_data_received)
            self.icon_theme.connect("changed", self.on_icon_theme_changed)

            self.request_state_refresh()
            self.start_hypr_event_listener()
            self.start_trash_monitor()
            GLib.timeout_add_seconds(60, self.request_state_refresh)

        def new_item(
            self,
            key,
            kind,
            action,
            label,
            asset_name,
            fallback_icon,
            desktop_id=None,
            match_patterns=(),
            removable=False,
        ):
            return {
                "key": key,
                "kind": kind,
                "action": action,
                "label": label,
                "asset_name": asset_name,
                "fallback_icon": fallback_icon,
                "desktop_id": desktop_id,
                "match_patterns": tuple(match_patterns),
                "removable": removable,
                "pixbuf": self.load_icon(asset_name, fallback_icon),
                "scale": 1.0,
                "target": 1.0,
                "velocity": 0.0,
                "layout_x": None,
                "layout_target_x": None,
                "layout_velocity": 0.0,
                "running": False,
                "bounce_start": None,
            }

        def rebuild_items(self, bounce_key=None, resize=True):
            old_items = {item.get("key"): item for item in self.items}
            pinned_items = []
            clean_keys = []
            for key in self.pinned_keys[:MAX_PINNED_ITEMS]:
                if key.startswith("builtin:"):
                    action = key.split(":", 1)[1]
                    if (
                        action == "launcher"
                        and shutil.which("villode-launcher") is None
                    ):
                        continue
                    spec = BUILTIN_ITEMS.get(action)
                    if spec is None:
                        continue
                    label, asset_name, fallback_icon = spec
                    item = self.new_item(
                        key,
                        "builtin",
                        action,
                        label,
                        asset_name,
                        fallback_icon,
                        match_patterns=(
                            file_manager_patterns()
                            if action == "files"
                            else RUNNING_CLASSES.get(action, ())
                        ),
                        removable=action not in {"files", "launcher"},
                    )
                elif key.startswith("desktop:"):
                    desktop_id = key.split(":", 1)[1]
                    entry = resolve_desktop_entry(desktop_id)
                    if entry is None:
                        continue
                    custom_asset = f"{desktop_id}.png"
                    if not (ICON_DIR / custom_asset).is_file():
                        custom_asset = None
                    item = self.new_item(
                        key,
                        "desktop",
                        None,
                        entry["name"],
                        custom_asset,
                        entry["icon"],
                        desktop_id=desktop_id,
                        match_patterns=entry["patterns"],
                        removable=True,
                    )
                else:
                    continue

                previous = old_items.get(key)
                if previous is not None:
                    for state_key in (
                        "scale",
                        "target",
                        "velocity",
                        "layout_x",
                        "layout_target_x",
                        "layout_velocity",
                        "running",
                        "bounce_start",
                    ):
                        item[state_key] = previous[state_key]
                pinned_items.append(item)
                clean_keys.append(key)

            if "builtin:files" not in clean_keys:
                label, asset_name, fallback_icon = BUILTIN_ITEMS["files"]
                pinned_items.insert(
                    0,
                    self.new_item(
                        "builtin:files",
                        "builtin",
                        "files",
                        label,
                        asset_name,
                        fallback_icon,
                        match_patterns=file_manager_patterns(),
                    ),
                )
                clean_keys.insert(0, "builtin:files")

            # Unpinned apps that currently have open windows (macOS Dock style).
            running_items = []
            covered_patterns = set()
            for item in pinned_items:
                for pattern in item.get("match_patterns") or ():
                    if pattern:
                        covered_patterns.add(str(pattern).lower())
            seen_running_keys = set()
            for client in self.clients or []:
                # Skip special / empty / dock-owned surfaces.
                cls = str(client.get("class") or client.get("initialClass") or "").strip()
                if not cls:
                    continue
                cls_l = cls.lower()
                if cls_l in SKIP_RUNNING_CLASSES:
                    continue
                if any(cls_l == p or cls_l.endswith("." + p) for p in covered_patterns):
                    continue
                # Already matched a pinned item via item_matches_client later — also
                # skip if any pinned pattern equals class/initialClass.
                initial = str(client.get("initialClass") or "").lower()
                if initial in covered_patterns or cls_l in covered_patterns:
                    continue
                desktop_id = desktop_id_for_window_class(cls) or desktop_id_for_window_class(
                    client.get("initialClass")
                )
                if desktop_id is None:
                    # Still show a transient running tile using the WM class.
                    key = f"running:{cls_l}"
                    if key in seen_running_keys:
                        continue
                    seen_running_keys.add(key)
                    item = self.new_item(
                        key,
                        "running",
                        None,
                        cls,
                        None,
                        cls_l,
                        match_patterns=(cls_l, initial) if initial else (cls_l,),
                        removable=False,
                    )
                    item["running"] = True
                    previous = old_items.get(key)
                    if previous is not None:
                        for state_key in (
                            "scale",
                            "target",
                            "velocity",
                            "layout_x",
                            "layout_target_x",
                            "layout_velocity",
                            "bounce_start",
                        ):
                            item[state_key] = previous[state_key]
                    running_items.append(item)
                    covered_patterns.add(cls_l)
                    if initial:
                        covered_patterns.add(initial)
                    continue

                # Map to a pinned builtin if applicable (browser/terminal).
                builtin = BUILTIN_DESKTOP_IDS.get(desktop_id.lower())
                if builtin and f"builtin:{builtin}" in clean_keys:
                    continue
                key = f"desktop:{desktop_id}"
                if key in clean_keys or key in seen_running_keys:
                    continue
                # Avoid duplicates when multiple windows share one app.
                seen_running_keys.add(key)
                entry = resolve_desktop_entry(desktop_id)
                if entry is None:
                    continue
                custom_asset = f"{desktop_id}.png"
                if not (ICON_DIR / custom_asset).is_file():
                    custom_asset = None
                item = self.new_item(
                    key,
                    "desktop",
                    None,
                    entry["name"],
                    custom_asset,
                    entry["icon"],
                    desktop_id=desktop_id,
                    match_patterns=entry["patterns"],
                    removable=True,
                )
                item["running"] = True
                previous = old_items.get(key)
                if previous is not None:
                    for state_key in (
                        "scale",
                        "target",
                        "velocity",
                        "layout_x",
                        "layout_target_x",
                        "layout_velocity",
                        "bounce_start",
                    ):
                        item[state_key] = previous[state_key]
                running_items.append(item)
                for pattern in entry["patterns"]:
                    covered_patterns.add(str(pattern).lower())

            place_items = []
            for action, label, asset_name, fallback_icon in PLACE_ITEMS:
                key = f"place:{action}"
                item = self.new_item(
                    key,
                    "place",
                    action,
                    label,
                    asset_name,
                    fallback_icon,
                )
                previous = old_items.get(key)
                if previous is not None:
                    for state_key in (
                        "scale",
                        "target",
                        "velocity",
                        "layout_x",
                        "layout_target_x",
                        "layout_velocity",
                        "running",
                        "bounce_start",
                    ):
                        item[state_key] = previous[state_key]
                place_items.append(item)

            self.pinned_keys = clean_keys
            # group_break = end of pinned+running, before places (downloads/trash)
            self.group_break = len(pinned_items) + len(running_items)
            self.items = pinned_items + running_items + place_items
            base_panel_width = (
                len(self.items) * BASE_SLOT_WIDTH
                + SEPARATOR_GAP
                + 2 * PANEL_PADDING
            )
            display = Gdk.Display.get_default()
            gdk_window = self.host_window.get_window()
            monitor = (
                display.get_monitor_at_window(gdk_window)
                if display is not None and gdk_window is not None
                else None
            )
            if monitor is None and display is not None:
                monitor = display.get_primary_monitor()
            if monitor is None and display is not None and display.get_n_monitors() > 0:
                monitor = display.get_monitor(0)
            monitor_width = (
                monitor.get_geometry().width if monitor is not None else SURFACE_WIDTH
            )
            screen_width = max(SURFACE_WIDTH, monitor_width)
            desired_width = min(
                screen_width - 8,
                max(SURFACE_WIDTH, base_panel_width + 120),
            )
            self.surface_width = int(desired_width)
            self.base_centers = self.compute_base_centers()
            self.layout = self.compute_layout(time.monotonic())
            self.last_input_rects = None
            self.hovered = None
            if bounce_key is not None:
                for item in self.items:
                    if item["key"] == bounce_key:
                        item["bounce_start"] = time.monotonic()
                        break
            if resize:
                self.set_size_request(self.surface_width, WINDOW_HEIGHT)
                self.host_window.resize(self.surface_width, WINDOW_HEIGHT)
                self.host_window.queue_resize()
                if self.edge_window is not None:
                    self.edge_window.resize(self.surface_width, 2)
                self.ensure_tick()
                self.queue_draw()

        def load_icon(self, asset_name, fallback_icon):
            asset_path = ICON_DIR / asset_name if asset_name else None
            if asset_path is not None and asset_path.is_file():
                try:
                    return GdkPixbuf.Pixbuf.new_from_file_at_scale(
                        str(asset_path), 128, 128, True
                    )
                except GLib.Error:
                    pass

            fallback_path = Path(fallback_icon) if fallback_icon else None
            if fallback_path is not None and fallback_path.is_file():
                try:
                    return GdkPixbuf.Pixbuf.new_from_file_at_scale(
                        str(fallback_path), 128, 128, True
                    )
                except GLib.Error:
                    pass

            candidates = [
                fallback_icon,
                "application-x-executable",
                "image-missing",
            ]
            for candidate in filter(None, candidates):
                try:
                    return self.icon_theme.load_icon(
                        candidate, 128, Gtk.IconLookupFlags.FORCE_SIZE
                    )
                except GLib.Error:
                    continue
            return None

        def on_icon_theme_changed(self, _theme):
            for item in self.items:
                item["pixbuf"] = self.load_icon(
                    item["asset_name"], item["fallback_icon"]
                )
            self.queue_draw()

        def compute_base_centers(self):
            content_width = len(self.items) * BASE_SLOT_WIDTH + SEPARATOR_GAP
            panel_width = content_width + 2 * PANEL_PADDING
            cursor = (self.surface_width - panel_width) / 2.0 + PANEL_PADDING
            centers = []
            for index in range(len(self.items)):
                if index == self.group_break:
                    cursor += SEPARATOR_GAP
                centers.append(cursor + BASE_SLOT_WIDTH / 2.0)
                cursor += BASE_SLOT_WIDTH
            return centers

        def bounce_offset(self, item, now):
            started = item["bounce_start"]
            if started is None:
                return 0.0
            progress = (now - started) / BOUNCE_DURATION
            if progress >= 1.0:
                item["bounce_start"] = None
                return 0.0
            if progress < 0.0:
                return 0.0
            envelope = min(1.0, (1.0 - progress) * 4.0 / 3.0)
            bounce = abs(math.sin(2.0 * math.pi * progress)) * envelope
            return -0.28 * BASE_ICON_SIZE * bounce

        def compute_layout(self, now):
            widths = [
                BASE_SLOT_WIDTH
                + max(0.0, item["scale"] - 1.0) * BASE_ICON_SIZE * 0.62
                for item in self.items
            ]
            preview_gap = EXTERNAL_DROP_GAP * self.external_gap
            gap_before = {}
            transition = 1.0
            previous_index = self.external_previous_drop_index
            if (
                self.external_index_transition_start is not None
                and previous_index is not None
                and previous_index != self.external_drop_index
            ):
                progress = max(
                    0.0,
                    min(
                        1.0,
                        (now - self.external_index_transition_start)
                        / EXTERNAL_INDEX_TRANSITION,
                    ),
                )
                transition = progress * progress * (3.0 - 2.0 * progress)
            if preview_gap > 0.01 and self.external_drop_index is not None:
                gap_before[self.external_drop_index] = preview_gap * transition
                if previous_index is not None and transition < 1.0:
                    gap_before[previous_index] = (
                        gap_before.get(previous_index, 0.0)
                        + preview_gap * (1.0 - transition)
                    )
            panel_width = (
                sum(widths)
                + SEPARATOR_GAP
                + preview_gap
                + 2 * PANEL_PADDING
            )
            panel_left = (self.surface_width - panel_width) / 2.0
            cursor = panel_left + PANEL_PADDING
            separator_x = None
            preview_center = None
            entries = [None] * len(self.items)
            internal_drag = (
                self.internal_drag_active
                and self.pressed is not None
                and 0 < self.pressed < self.group_break
            )
            dragged_index = self.pressed if internal_drag else None
            dragged_width = widths[dragged_index] if internal_drag else 0.0
            drop_index = (
                max(
                    1,
                    min(
                        int(
                            self.internal_drop_index
                            if self.internal_drop_index is not None
                            else dragged_index
                        ),
                        self.group_break - 1,
                    ),
                )
                if internal_drag
                else None
            )
            app_order = list(range(self.group_break))
            if internal_drag:
                app_order.remove(dragged_index)
                app_order.insert(drop_index, None)
            layout_order = app_order + list(range(self.group_break, len(self.items)))

            for token in layout_order:
                if token is None:
                    preview_center = cursor + dragged_width / 2.0
                    cursor += dragged_width
                    continue
                index = token
                item = self.items[index]
                slot_width = widths[index]
                external_gap_here = gap_before.get(index, 0.0)
                if external_gap_here > 0.01 and index <= self.group_break:
                    if index == self.external_drop_index:
                        preview_center = cursor + external_gap_here / 2.0
                    cursor += external_gap_here
                if index == self.group_break:
                    separator_x = cursor + SEPARATOR_GAP / 2.0
                    cursor += SEPARATOR_GAP
                center_x = cursor + slot_width / 2.0
                icon_size = BASE_ICON_SIZE * item["scale"]
                icon_y = ICON_BOTTOM - icon_size + self.bounce_offset(item, now)
                entries[index] = {
                    "index": index,
                    "center_x": center_x,
                    "slot_left": cursor,
                    "slot_right": cursor + slot_width,
                    "icon_x": center_x - icon_size / 2.0,
                    "icon_y": icon_y,
                    "icon_size": icon_size,
                }
                cursor += slot_width

            if (
                preview_gap > 0.01
                and self.external_drop_index == self.group_break
                and self.group_break == len(self.items)
            ):
                preview_center = cursor + gap_before.get(
                    self.group_break, preview_gap
                ) / 2.0

            # Keep the magnified cluster under the pointer.  Centering every
            # expanded frame would make an edge icon slide away as it grows;
            # this weighted correction instead pushes its neighbours aside.
            if internal_drag:
                item = self.items[dragged_index]
                remove_scale = 0.82 if self.internal_remove_armed else 1.0
                icon_size = BASE_ICON_SIZE * item["scale"] * remove_scale
                center_x = max(
                    icon_size / 2.0 + 3.0,
                    min(self.surface_width - icon_size / 2.0 - 3.0, self.pointer_x),
                )
                icon_y = max(
                    3.0,
                    min(WINDOW_HEIGHT - icon_size - 3.0, self.pointer_y - icon_size / 2.0),
                )
                entries[dragged_index] = {
                    "index": dragged_index,
                    "center_x": center_x,
                    "slot_left": center_x - dragged_width / 2.0,
                    "slot_right": center_x + dragged_width / 2.0,
                    "icon_x": center_x - icon_size / 2.0,
                    "icon_y": icon_y,
                    "icon_size": icon_size,
                }

            weights = (
                [0.0] * len(self.items)
                if internal_drag
                else [max(0.0, item["scale"] - 1.0) ** 2 for item in self.items]
            )
            weight_sum = sum(weights)
            if weight_sum > 1e-6:
                shift = sum(
                    weight * (rest_center - entry["center_x"])
                    for weight, rest_center, entry in zip(
                        weights, self.base_centers, entries
                    )
                ) / weight_sum
                shift = max(
                    4.0 - panel_left,
                    min(
                        self.surface_width - 4.0 - panel_left - panel_width,
                        shift,
                    ),
                )
                panel_left += shift
                if separator_x is not None:
                    separator_x += shift
                if preview_center is not None:
                    preview_center += shift
                for entry in entries:
                    entry["center_x"] += shift
                    entry["slot_left"] += shift
                    entry["slot_right"] += shift
                    entry["icon_x"] += shift

            # Slot changes during an internal reorder are discrete, but the
            # neighbouring icons should glide into those slots.  Keep the
            # dragged icon directly under the pointer and spring every other
            # icon towards its newly computed centre.
            for entry, item in zip(entries, self.items):
                target_x = entry["center_x"]
                item["layout_target_x"] = target_x
                if internal_drag and entry["index"] == dragged_index:
                    item["layout_x"] = target_x
                    item["layout_velocity"] = 0.0
                    continue
                if item["layout_x"] is None:
                    item["layout_x"] = target_x
                delta = item["layout_x"] - target_x
                entry["center_x"] += delta
                entry["slot_left"] += delta
                entry["slot_right"] += delta
                entry["icon_x"] += delta

            return {
                "panel_left": panel_left,
                "panel_width": panel_width,
                "separator_x": separator_x,
                "preview_center": preview_center,
                "items": entries,
            }

        def update_targets(self):
            for item, center in zip(self.items, self.base_centers):
                target = 1.0
                if self.pointer_inside:
                    distance = abs(center - self.pointer_x)
                    if distance < WAVE_RADIUS:
                        influence = math.cos(math.pi * distance / (2.0 * WAVE_RADIUS))
                        target += (MAX_SCALE - 1.0) * influence
                item["target"] = target
            self.ensure_tick()

        def ensure_tick(self):
            if self.tick_id is None:
                self.last_frame_us = None
                self.tick_id = self.add_tick_callback(self.on_tick)

        def on_tick(self, _widget, frame_clock):
            frame_us = frame_clock.get_frame_time()
            if (
                self.last_frame_us is not None
                and frame_us - self.last_frame_us < MIN_ANIMATION_FRAME_US
            ):
                return True
            if self.last_frame_us is None:
                dt = 1.0 / 60.0
            else:
                dt = max(1.0 / 240.0, min(0.034, (frame_us - self.last_frame_us) / 1_000_000.0))
            self.last_frame_us = frame_us

            moving = False
            now = time.monotonic()
            gap_error = self.external_gap_target - self.external_gap
            self.external_gap_velocity += gap_error * 190.0 * dt
            self.external_gap_velocity *= math.exp(-16.0 * dt)
            self.external_gap += self.external_gap_velocity * dt
            self.external_gap = max(0.0, min(1.08, self.external_gap))
            if (
                abs(gap_error) < 0.001
                and abs(self.external_gap_velocity) < 0.004
            ):
                self.external_gap = self.external_gap_target
                self.external_gap_velocity = 0.0
                if self.external_gap <= 0.0:
                    self.external_drop_index = None
                    self.external_previous_drop_index = None
                    self.external_index_transition_start = None
            else:
                moving = True
            if self.external_index_transition_start is not None:
                if (
                    now - self.external_index_transition_start
                    < EXTERNAL_INDEX_TRANSITION
                ):
                    moving = True
                else:
                    self.external_previous_drop_index = None
                    self.external_index_transition_start = None
            for item in self.items:
                error = item["target"] - item["scale"]
                item["velocity"] += error * 165.0 * dt
                item["velocity"] *= math.exp(-13.5 * dt)
                item["scale"] += item["velocity"] * dt
                item["scale"] = max(0.96, min(MAX_SCALE + 0.07, item["scale"]))
                if abs(error) < 0.001 and abs(item["velocity"]) < 0.004:
                    item["scale"] = item["target"]
                    item["velocity"] = 0.0
                else:
                    moving = True
                if item["bounce_start"] is not None:
                    if now - item["bounce_start"] < BOUNCE_DURATION:
                        moving = True
                    else:
                        item["bounce_start"] = None

                if item["layout_target_x"] is not None:
                    layout_error = item["layout_target_x"] - item["layout_x"]
                    item["layout_velocity"] += layout_error * LAYOUT_SPRING * dt
                    item["layout_velocity"] *= math.exp(-LAYOUT_DAMPING * dt)
                    item["layout_x"] += item["layout_velocity"] * dt
                    if (
                        abs(layout_error) < 0.03
                        and abs(item["layout_velocity"]) < 0.08
                    ):
                        item["layout_x"] = item["layout_target_x"]
                        item["layout_velocity"] = 0.0
                    else:
                        moving = True

            self.layout = self.compute_layout(now)
            if self.pointer_inside and self.pressed is None:
                self.set_hovered(self.hit_test(self.pointer_x, self.pointer_y))
            tooltip_pending = (
                self.pointer_inside
                and self.hovered is not None
                and now - self.hover_since < TOOLTIP_DELAY
            )
            self.queue_draw()
            if moving or tooltip_pending:
                return True

            self.tick_id = None
            self.last_frame_us = None
            return False

        def hit_test(self, x, y):
            if y > WINDOW_HEIGHT:
                return None
            for entry in self.layout["items"]:
                top = min(PANEL_TOP, entry["icon_y"] - 4.0)
                if (
                    entry["slot_left"] <= x <= entry["slot_right"]
                    and top <= y <= WINDOW_HEIGHT
                ):
                    return entry["index"]
            return None

        def insertion_index_for_x(self, x):
            app_entries = self.layout["items"][: self.group_break]
            for index, entry in enumerate(app_entries):
                if x < entry["center_x"]:
                    return max(1, index)
            return max(1, self.group_break)

        def external_insertion_index_for_x(self, x):
            candidate = self.insertion_index_for_x(x)
            current = self.external_drop_index
            if current is None or candidate == current:
                return candidate
            if abs(candidate - current) > 1:
                return candidate
            if candidate > current and current < self.group_break:
                boundary = self.layout["items"][current]["center_x"]
                if x < boundary + EXTERNAL_INDEX_HYSTERESIS:
                    return current
            elif candidate < current and current > 0:
                boundary = self.layout["items"][current - 1]["center_x"]
                if x > boundary - EXTERNAL_INDEX_HYSTERESIS:
                    return current
            return candidate

        def internal_index_for_x(self, x):
            entries = sorted(
                (
                    entry
                    for entry in self.layout["items"][: self.group_break]
                    if entry["index"] != self.pressed
                ),
                key=lambda entry: entry["center_x"],
            )
            index = sum(1 for entry in entries if x >= entry["center_x"])
            return max(1, min(index, max(1, self.group_break - 1)))

        def update_internal_remove_state(self, y):
            armed = self.internal_remove_armed
            removable = (
                self.internal_drag_active
                and self.pressed is not None
                and 0 <= self.pressed < self.group_break
                and self.items[self.pressed]["removable"]
            )
            if not removable:
                armed = False
            elif armed:
                armed = float(y) < REMOVE_DISARM_Y
            else:
                armed = float(y) <= REMOVE_ARM_Y
            if armed != self.internal_remove_armed:
                self.internal_remove_armed = armed
                self.update_pointer_cursor()
                self.queue_draw()

        def reset_drop_preview(self, clear_pending=True):
            self.external_drag_active = False
            self.external_gap_target = 0.0
            if clear_pending:
                self.pending_drop_index = None
            self.internal_drag_active = False
            self.internal_drop_index = None
            self.internal_remove_armed = False
            self.last_input_rects = None
            self.layout = self.compute_layout(time.monotonic())
            self.ensure_tick()
            self.queue_draw()

        def on_custom_drag_motion(self, x, y):
            self.pending_drop_index = None
            self.pointer_inside = True
            self.pointer_x = float(x)
            self.pointer_y = float(y)
            self.external_drag_active = True
            self.external_gap_target = 1.0
            next_index = self.external_insertion_index_for_x(self.pointer_x)
            if next_index != self.external_drop_index:
                self.external_previous_drop_index = self.external_drop_index
                self.external_drop_index = next_index
                self.external_index_transition_start = (
                    time.monotonic()
                    if self.external_previous_drop_index is not None
                    else None
                )
            self.layout = self.compute_layout(time.monotonic())
            self.update_targets()
            self.queue_draw()

        def on_custom_drag_leave(self):
            self.pointer_inside = False
            self.set_hovered(None)
            self.update_targets()
            self.reset_drop_preview()

        def on_drag_motion(self, _widget, context, x, y, event_time):
            target = self.drag_dest_find_target(context, None)
            if target is None:
                return False
            if not self.external_drag_active:
                self.pending_drop_index = None
            self.pointer_inside = True
            self.pointer_x, self.pointer_y = float(x), float(y)
            self.external_drag_active = True
            self.external_gap_target = 1.0
            next_index = self.external_insertion_index_for_x(x)
            if next_index != self.external_drop_index:
                self.external_previous_drop_index = self.external_drop_index
                self.external_drop_index = next_index
                self.external_index_transition_start = (
                    time.monotonic()
                    if self.external_previous_drop_index is not None
                    else None
                )
            self.layout = self.compute_layout(time.monotonic())
            self.update_targets()
            self.queue_draw()
            Gdk.drag_status(context, Gdk.DragAction.COPY, event_time)
            return True

        def on_drag_leave(self, _widget, _context, _event_time):
            self.pointer_inside = False
            self.update_targets()
            self.reset_drop_preview(clear_pending=False)

        def on_drag_drop(self, _widget, context, x, _y, event_time):
            target = self.drag_dest_find_target(context, None)
            if target is None:
                return False
            self.pending_drop_index = self.insertion_index_for_x(x)
            self.drag_get_data(context, target, event_time)
            return True

        def desktop_id_from_drop(self, selection_data, info):
            if info == 0:
                raw = selection_data.get_data()
                if not raw:
                    return None
                try:
                    payload = json.loads(bytes(raw).decode("utf-8"))
                except (UnicodeDecodeError, json.JSONDecodeError, TypeError):
                    return None
                if not isinstance(payload, dict) or payload.get("kind") != "application":
                    return None
                desktop_id = payload.get("desktop_id")
                return desktop_id if valid_desktop_id(desktop_id) else None

            raw = selection_data.get_data()
            if not raw:
                return None
            try:
                lines = bytes(raw).decode("utf-8").splitlines()
            except UnicodeDecodeError:
                return None
            for line in lines:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parsed = urlparse(line)
                if parsed.scheme != "file":
                    continue
                desktop_id = Path(unquote(parsed.path)).name
                if valid_desktop_id(desktop_id):
                    return desktop_id
            return None

        def on_drag_data_received(
            self, _widget, context, _x, _y, selection_data, info, event_time
        ):
            desktop_id = self.desktop_id_from_drop(selection_data, info)
            index = self.pending_drop_index
            if index is None:
                index = self.external_drop_index
            success = desktop_id is not None and self.pin_desktop(
                desktop_id, index if index is not None else self.group_break
            )
            Gtk.drag_finish(context, success, False, event_time)
            self.reset_drop_preview()

        def pin_desktop(self, desktop_id, insertion_index):
            entry = resolve_desktop_entry(desktop_id)
            if entry is None:
                return False
            builtin_action = BUILTIN_DESKTOP_IDS.get(desktop_id.lower())
            key = (
                f"builtin:{builtin_action}"
                if builtin_action is not None
                else f"desktop:{desktop_id}"
            )
            keys = list(self.pinned_keys)
            if key == "builtin:files":
                return True
            insertion_index = max(1, min(int(insertion_index), len(keys)))
            if key in keys:
                old_index = keys.index(key)
                keys.pop(old_index)
                if insertion_index > old_index:
                    insertion_index -= 1
            elif len(keys) >= MAX_PINNED_ITEMS:
                return False
            keys.insert(max(1, min(insertion_index, len(keys))), key)
            self.pinned_keys = keys
            save_pinned_keys(keys)
            self.rebuild_items(bounce_key=key)
            return True

        def pin_item(self, item):
            """Pin an unpinned running tile (or any desktop tile) to the Dock."""
            if not item:
                return False
            key = item.get("key") or ""
            if key in self.pinned_keys:
                return True
            desktop_id = item.get("desktop_id")
            if not desktop_id and key.startswith("desktop:"):
                desktop_id = key.split(":", 1)[1]
            if not desktop_id and key.startswith("running:"):
                # Resolve .desktop from the live window class.
                wm_class = key.split(":", 1)[1]
                desktop_id = desktop_id_for_window_class(wm_class)
                if not desktop_id:
                    client = self.matching_client(item)
                    if client is not None:
                        desktop_id = desktop_id_for_window_class(
                            client.get("class")
                        ) or desktop_id_for_window_class(client.get("initialClass"))
            if not desktop_id:
                return False
            # Append after the last currently pinned item (before running/places).
            return self.pin_desktop(desktop_id, len(self.pinned_keys))

        def item_is_pinned(self, item):
            key = (item or {}).get("key") or ""
            if key in self.pinned_keys:
                return True
            desktop_id = (item or {}).get("desktop_id")
            if desktop_id:
                builtin = BUILTIN_DESKTOP_IDS.get(str(desktop_id).lower())
                if builtin and f"builtin:{builtin}" in self.pinned_keys:
                    return True
                if f"desktop:{desktop_id}" in self.pinned_keys:
                    return True
            return False

        def unpin_key(self, key):
            if key in {"builtin:files", "builtin:launcher"}:
                return
            if key not in self.pinned_keys:
                return
            self.pinned_keys = [item for item in self.pinned_keys if item != key]
            save_pinned_keys(self.pinned_keys)
            self.rebuild_items()

        def reorder_pinned(self, old_index, new_index):
            if old_index <= 0 or old_index >= len(self.pinned_keys):
                return
            keys = list(self.pinned_keys)
            key = keys.pop(old_index)
            new_index = max(1, min(new_index, len(keys)))
            keys.insert(new_index, key)
            if keys == self.pinned_keys:
                return
            self.pinned_keys = keys
            save_pinned_keys(keys)
            self.rebuild_items()

        def set_hovered(self, index):
            if index == self.hovered:
                return
            self.hovered = index
            self.hover_since = time.monotonic()
            self.update_pointer_cursor()
            self.ensure_tick()
            self.queue_draw()

        def update_pointer_cursor(self):
            window = self.get_window()
            if window is not None:
                if self.internal_remove_armed:
                    cursor_name = "not-allowed"
                elif self.internal_drag_active:
                    cursor_name = "grabbing"
                else:
                    cursor_name = "pointer" if self.hovered is not None else "default"
                window.set_cursor(Gdk.Cursor.new_from_name(window.get_display(), cursor_name))

        def on_enter(self, _widget, event):
            self.cancel_fullscreen_hide()
            self.pointer_inside = True
            self.pointer_x, self.pointer_y = event.x, event.y
            self.set_hovered(self.hit_test(event.x, event.y))
            self.update_targets()
            return True

        def on_motion(self, _widget, event):
            self.pointer_inside = True
            self.pointer_x, self.pointer_y = event.x, event.y
            if (
                self.pressed is not None
                and self.press_position is not None
                and not getattr(self, "pressed_clicked", False)
                and 0 < self.pressed < self.group_break
            ):
                dist = math.hypot(
                    event.x - self.press_position[0],
                    event.y - self.press_position[1],
                )
                elapsed = time.monotonic() - getattr(self, "press_time", 0.0)
                # Start drag on ANY movement after the hold threshold.
                # Before the threshold, require an 8px move to avoid accidental drags.
                can_start_drag = elapsed >= 0.4 or dist >= 8.0
                if can_start_drag and not self.internal_drag_active:
                    self.internal_drag_active = True
                    self.internal_drop_index = self.internal_index_for_x(event.x)
                    self.update_internal_remove_state(event.y)
                    self.pointer_inside = not self.internal_remove_armed
                    self.update_pointer_cursor()
                elif self.internal_drag_active:
                    self.internal_drop_index = self.internal_index_for_x(event.x)
                    self.update_internal_remove_state(event.y)
                    self.pointer_inside = not self.internal_remove_armed
                    self.update_pointer_cursor()
            self.set_hovered(self.hit_test(event.x, event.y))
            self.update_targets()
            self.queue_draw()
            return True

        def on_leave(self, _widget, event):
            self.pointer_inside = False
            if self.internal_drag_active and self.pressed is not None:
                self.pointer_x, self.pointer_y = event.x, event.y
                self.update_internal_remove_state(event.y)
                self.set_hovered(None)
                self.update_targets()
                self.queue_draw()
                return True
            self.pressed = None
            self.press_position = None
            self.internal_drag_active = False
            self.internal_drop_index = None
            self.internal_remove_armed = False
            self.set_hovered(None)
            self.update_targets()
            self.schedule_fullscreen_hide()
            return True

        def cancel_fullscreen_hide(self):
            if self.fullscreen_hide_id is not None:
                GLib.source_remove(self.fullscreen_hide_id)
                self.fullscreen_hide_id = None

        def schedule_fullscreen_hide(self):
            if (
                self.fullscreen_hidden
                and self.fullscreen_revealed
                and not self.external_drag_active
                and not self.internal_drag_active
                and self.fullscreen_hide_id is None
            ):
                self.fullscreen_hide_id = GLib.timeout_add(
                    140, self.finish_fullscreen_hide
                )

        def finish_fullscreen_hide(self):
            self.fullscreen_hide_id = None
            if (
                self.fullscreen_hidden
                and not self.pointer_inside
                and not self.external_drag_active
                and not self.internal_drag_active
            ):
                self.fullscreen_revealed = False
                self.host_window.hide()
                if self.edge_window is not None:
                    self.edge_window.show_all()
            return GLib.SOURCE_REMOVE

        def reveal_fullscreen(self, *_args):
            if not self.fullscreen_hidden or self.fullscreen_revealed:
                return False
            self.cancel_fullscreen_hide()
            self.fullscreen_revealed = True
            if self.edge_window is not None:
                self.edge_window.hide()
            self.host_window.show_all()
            return False

        def on_button_press(self, _widget, event):
            GlassContextMenu.close_active()
            GlassAboutDialog.close_active()
            index = self.hit_test(event.x, event.y)
            if event.button == Gdk.BUTTON_PRIMARY:
                self.pressed = index
                self.press_position = (event.x, event.y)
                self.press_time = time.monotonic()
                self.pressed_clicked = False
                self.queue_draw()
                return index is not None
            if event.button == Gdk.BUTTON_SECONDARY:
                self.show_context_menu(event, index)
                return True
            return False

        def on_button_release(self, _widget, event):
            if event.button != Gdk.BUTTON_PRIMARY:
                return False
            released = self.hit_test(event.x, event.y)
            pressed = self.pressed
            press_position = self.press_position
            press_time = getattr(self, "press_time", 0.0)
            clicked = getattr(self, "pressed_clicked", False)
            internal_drag = self.internal_drag_active
            internal_drop_index = self.internal_drop_index
            remove_armed = self.internal_remove_armed
            remove_key = (
                self.items[pressed]["key"]
                if (
                    remove_armed
                    and pressed is not None
                    and 0 <= pressed < self.group_break
                    and self.items[pressed]["removable"]
                )
                else None
            )
            self.pressed = None
            self.press_position = None
            self.press_time = 0.0
            self.pressed_clicked = False
            self.internal_drag_active = False
            self.internal_drop_index = None
            self.internal_remove_armed = False
            self.update_pointer_cursor()
            self.queue_draw()
            if remove_key is not None:
                self.unpin_key(remove_key)
                return True
            if (
                internal_drag
                and pressed is not None
                and internal_drop_index is not None
            ):
                self.reorder_pinned(pressed, internal_drop_index)
                return True
            stayed_put = (
                press_position is not None
                and math.hypot(
                    event.x - press_position[0], event.y - press_position[1]
                ) < 10.0
            )
            duration = time.monotonic() - press_time if press_time else 0.0
            if pressed is not None and not clicked and stayed_put and duration < 0.4:
                self.activate(pressed)
                return True
            return False

        def item_matches_client(self, item, client):
            values = (
                str(client.get("class", "")).lower(),
                str(client.get("initialClass", "")).lower(),
            )
            patterns = item["match_patterns"]
            if item["action"] == "terminal":
                patterns = terminal_window_classes(terminal_command())
            elif item["action"] == "browser":
                patterns = browser_window_classes(browser_command())
            for pattern in patterns:
                if not pattern:
                    continue
                p = str(pattern).lower()
                for value in values:
                    if not value:
                        continue
                    if p == value or value.endswith("." + p) or p.endswith("." + value):
                        return True
                    # chrome / google-chrome soft match
                    if p.replace("-", "") == value.replace("-", ""):
                        return True
            return False

        def matching_client(self, item):
            for client in self.clients:
                if self.item_matches_client(item, client):
                    return client
            return None

        def focus_client(self, client):
            address = str(client.get("address", ""))
            if not address:
                return False
            return spawn_command(["hyprctl", "dispatch", "focuswindow", f"address:{address}"])

        def activate(self, index, force_new=False):
            item = self.items[index]
            focusable = (
                item["kind"] in {"desktop", "running"}
                or item["action"] in FOCUSABLE
            )
            if focusable and not force_new:
                client = self.matching_client(item)
                if client is not None and self.focus_client(client):
                    return
            if item["kind"] == "desktop" and item.get("desktop_id"):
                command = ["gtk-launch", item["desktop_id"]]
            elif item["kind"] == "running":
                # No desktop file — just try to focus; cannot launch again.
                return
            elif item["action"] == "files":
                command = file_manager_command(Path.home())
            elif item["action"] == "downloads":
                command = file_manager_command(DOWNLOAD_DIR)
            elif item["action"] == "trash":
                command = file_manager_command("trash:///")
            elif item["action"] == "terminal":
                command = terminal_command()
            elif item["action"] == "browser":
                command = browser_command()
            else:
                command = ACTIONS.get(item["action"])
                if not command:
                    return
            if spawn_command(command):
                item["bounce_start"] = time.monotonic()
                self.ensure_tick()

        def menu_item(self, label, callback):
            # Kept for compatibility; glass menus use entry dicts instead.
            item = Gtk.MenuItem.new_with_label(label)
            item.connect("activate", callback)
            return item

        def empty_trash(self):
            dialog = Gtk.MessageDialog(
                transient_for=self.host_window,
                modal=True,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.NONE,
                text="确定要清空废纸篓吗？",
            )
            dialog.format_secondary_text(
                "废纸篓中的项目将被永久删除，此操作无法撤销。"
            )
            dialog.add_button("取消", Gtk.ResponseType.CANCEL)
            dialog.add_button("清空废纸篓", Gtk.ResponseType.ACCEPT)
            dialog.set_default_response(Gtk.ResponseType.CANCEL)
            response = dialog.run()
            dialog.destroy()
            if response != Gtk.ResponseType.ACCEPT:
                return

            def worker():
                try:
                    result = subprocess.run(
                        ["gio", "trash", "--empty"],
                        check=False,
                        stdin=subprocess.DEVNULL,
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        timeout=30,
                    )
                    success = result.returncode == 0
                except (OSError, subprocess.TimeoutExpired):
                    success = False
                GLib.idle_add(self.finish_empty_trash, success)

            threading.Thread(target=worker, daemon=True).start()

        def finish_empty_trash(self, success):
            if success:
                if self.apply_trash_state(False):
                    self.queue_draw()
                self.request_state_refresh()
                return GLib.SOURCE_REMOVE

            dialog = Gtk.MessageDialog(
                transient_for=self.host_window,
                modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.CLOSE,
                text="无法清空废纸篓",
            )
            dialog.format_secondary_text(
                "系统未能完成清理，请打开文件管理器后重试。"
            )
            dialog.run()
            dialog.destroy()
            return GLib.SOURCE_REMOVE

        def show_about(self):
            GlassAboutDialog(self.host_window).popup()

        def show_context_menu(self, event, index):
            entries = []
            if index is not None:
                dock_item = self.items[index]
                label = dock_item["label"]
                entries.append(
                    {
                        "label": f"打开“{label}”",
                        "callback": lambda i=index: self.activate(i),
                    }
                )
                if (
                    dock_item["kind"] in {"desktop", "running"}
                    or dock_item["action"] in FOCUSABLE
                ):
                    if dock_item["kind"] != "running" or dock_item.get("desktop_id"):
                        entries.append(
                            {
                                "label": "打开新窗口",
                                "callback": lambda i=index: self.activate(
                                    i, force_new=True
                                ),
                            }
                        )
                if dock_item["action"] == "trash":
                    entries.append(
                        {
                            "label": "清空废纸篓…",
                            "callback": self.empty_trash,
                            "sensitive": self.trash_full,
                        }
                    )

                pinned = self.item_is_pinned(dock_item)
                if not pinned and dock_item["kind"] in {"desktop", "running"}:
                    can_pin = bool(
                        dock_item.get("desktop_id")
                        or (dock_item.get("key") or "").startswith("desktop:")
                        or desktop_id_for_window_class(
                            (dock_item.get("key") or "").split(":", 1)[-1]
                        )
                    )
                    entries.append(
                        {
                            "label": "固定到 Dock",
                            "callback": lambda it=dock_item: self.pin_item(it),
                            "sensitive": can_pin,
                        }
                    )
                elif pinned and dock_item["removable"]:
                    entries.append(
                        {
                            "label": "从 Dock 移除",
                            "callback": lambda key=dock_item["key"]: self.unpin_key(
                                key
                            ),
                        }
                    )
                entries.append({"separator": True})

            entries.append(
                {
                    "label": "重新载入 Dock",
                    "callback": lambda: spawn_command(
                        [sys.executable, str(SCRIPT), "--reload"]
                    ),
                }
            )
            entries.append(
                {
                    "label": "关于 Villode Dock…",
                    "callback": self.show_about,
                }
            )

            # Absolute compositor coords from Hyprland layer geometry (Wayland-safe).
            # GDK get_origin() is often (0,0) on layer-shell surfaces.
            dock_layer, _mon = find_layer_by_namespace("villode-dock")
            if dock_layer is not None:
                ox = float(dock_layer.get("x", 0))
                oy = float(dock_layer.get("y", 0))
            else:
                ox = oy = 0.0

            if index is not None and self.layout and index < len(
                self.layout.get("items", [])
            ):
                entry = self.layout["items"][index]
                screen_x = ox + float(entry["center_x"])
                screen_y = oy + float(PANEL_TOP) - 10.0
            else:
                screen_x = ox + float(event.x)
                screen_y = oy + float(event.y)

            GlassContextMenu.close_active()
            GlassContextMenu(self.host_window, entries, screen_x, screen_y).popup()

        def request_state_refresh(self):
            if self.refresh_in_flight:
                self.refresh_pending = True
                return True
            self.update_monitor_geometry()
            self.refresh_in_flight = True
            self.refresh_pending = False
            threading.Thread(target=self.state_refresh_worker, daemon=True).start()
            return True

        def update_monitor_geometry(self):
            display = self.host_window.get_display()
            gdk_window = self.host_window.get_window()
            if display is None or gdk_window is None:
                return
            monitor = display.get_monitor_at_window(gdk_window)
            if monitor is None:
                return
            geometry = monitor.get_geometry()
            self.monitor_geometry = (
                float(geometry.x),
                float(geometry.y),
                float(geometry.width),
                float(geometry.height),
            )

        def request_state_refresh_once(self):
            self.request_state_refresh()
            return GLib.SOURCE_REMOVE

        def start_hypr_event_listener(self):
            signature = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE", "")
            runtime_dir = os.environ.get(
                "XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"
            )
            if not signature:
                return
            event_socket = Path(runtime_dir) / "hypr" / signature / ".socket2.sock"

            def listen():
                while True:
                    try:
                        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as stream:
                            stream.connect(str(event_socket))
                            with stream.makefile("r", encoding="utf-8", errors="replace") as events:
                                for line in events:
                                    if line.startswith(
                                        (
                                            "openwindow>>",
                                            "closewindow>>",
                                            "fullscreen>>",
                                            "fullscreenstate>>",
                                            "workspace>>",
                                            "workspacev2>>",
                                            "focusedmon>>",
                                        )
                                    ):
                                        GLib.idle_add(self.request_state_refresh_once)
                    except OSError:
                        time.sleep(2.0)

            threading.Thread(target=listen, daemon=True).start()

        def start_trash_monitor(self):
            trash_path = Path.home() / ".local" / "share" / "Trash" / "files"
            try:
                self.trash_monitor = Gio.File.new_for_path(
                    str(trash_path)
                ).monitor_directory(Gio.FileMonitorFlags.NONE, None)
            except GLib.Error:
                self.trash_monitor = None
                return

            def trash_changed(*_args):
                self.request_state_refresh()

            self.trash_monitor.connect("changed", trash_changed)

        def state_refresh_worker(self):
            clients = hypr_clients()
            fullscreen = hypr_monitor_fullscreen(self.monitor_geometry, clients)
            files_patterns = file_manager_patterns()
            trash_path = Path.home() / ".local" / "share" / "Trash" / "files"
            try:
                trash_full = any(trash_path.iterdir())
            except (FileNotFoundError, PermissionError, OSError):
                trash_full = False
            GLib.idle_add(
                self.apply_refreshed_state,
                clients,
                trash_full,
                fullscreen,
                files_patterns,
            )

        def apply_refreshed_state(
            self, clients, trash_full, fullscreen, files_patterns
        ):
            self.refresh_in_flight = False
            clients_changed = False
            if clients is not None:
                # Detect open/close so unpinned running apps can appear/disappear.
                old_addrs = {
                    str(c.get("address", ""))
                    for c in (self.clients or [])
                    if c.get("address")
                }
                new_addrs = {
                    str(c.get("address", ""))
                    for c in clients
                    if c.get("address")
                }
                clients_changed = old_addrs != new_addrs
                self.clients = clients
            if fullscreen is not None:
                self.set_fullscreen_hidden(fullscreen)

            if clients_changed:
                # Rebuild so unpinned open apps show as temporary Dock tiles.
                self.rebuild_items(resize=True)
            else:
                changed = False
                for item in self.items:
                    if item["action"] == "files":
                        item["match_patterns"] = tuple(files_patterns)
                    running = bool(item["match_patterns"]) and any(
                        self.item_matches_client(item, client)
                        for client in self.clients
                    )
                    if running != item["running"]:
                        item["running"] = running
                        changed = True
                if self.apply_trash_state(trash_full):
                    changed = True
                if changed:
                    self.queue_draw()

            if clients_changed:
                self.apply_trash_state(trash_full)

            if self.refresh_pending:
                self.refresh_pending = False
                self.request_state_refresh()
            return False

        def set_fullscreen_hidden(self, hidden):
            hidden = bool(hidden)
            if hidden == self.fullscreen_hidden:
                return
            self.fullscreen_hidden = hidden
            if hidden:
                self.cancel_fullscreen_hide()
                self.fullscreen_revealed = False
                self.host_window.hide()
                if self.reserve_window is not None:
                    self.reserve_window.hide()
                if self.edge_window is not None:
                    self.edge_window.show_all()
            else:
                self.cancel_fullscreen_hide()
                self.fullscreen_revealed = False
                if self.edge_window is not None:
                    self.edge_window.hide()
                if self.reserve_window is not None:
                    self.reserve_window.show_all()
                self.host_window.show_all()

        def apply_trash_state(self, trash_full):
            self.trash_full = bool(trash_full)
            trash_item = next(
                (
                    item
                    for item in self.items
                    if item["kind"] == "place" and item["action"] == "trash"
                ),
                None,
            )
            if trash_item is None:
                return False
            asset_name = "trash-full.png" if trash_full else "trash-empty.png"
            fallback_icon = "user-trash-full" if trash_full else "user-trash"
            if trash_item["asset_name"] != asset_name:
                trash_item["asset_name"] = asset_name
                trash_item["fallback_icon"] = fallback_icon
                trash_item["pixbuf"] = self.load_icon(asset_name, fallback_icon)
                return True
            return False

        def apply_input_region(self):
            gdk_window = self.host_window.get_window()
            if gdk_window is None:
                return

            panel_left = math.floor(self.layout["panel_left"])
            panel_right = math.ceil(
                self.layout["panel_left"] + self.layout["panel_width"]
            )
            rects = [
                (
                    panel_left,
                    PANEL_TOP,
                    max(1, panel_right - panel_left),
                    WINDOW_HEIGHT - PANEL_TOP,
                )
            ]
            for entry in self.layout["items"]:
                left = math.floor(entry["icon_x"] - 3.0)
                top = math.floor(entry["icon_y"] - 3.0)
                right = math.ceil(entry["icon_x"] + entry["icon_size"] + 3.0)
                bottom = math.ceil(entry["icon_y"] + entry["icon_size"] + 3.0)
                rects.append((left, top, max(1, right - left), max(1, bottom - top)))

            rects_tuple = tuple(rects)
            if rects_tuple == self.last_input_rects:
                return
            region = cairo.Region()
            for x, y, width, height in rects:
                region.union(cairo.RectangleInt(int(x), int(y), int(width), int(height)))
            gdk_window.input_shape_combine_region(region, 0, 0)
            self.last_input_rects = rects_tuple

        def draw_panel(self, cr):
            left = self.layout["panel_left"]
            width = self.layout["panel_width"]
            height = PANEL_BOTTOM - PANEL_TOP

            # The alpha is the mask consumed by Hyprland's blur layer rule.  No
            # pre-baked blur/noise image is used; wallpaper/windows are sampled live.
            rounded_rectangle(cr, left, PANEL_TOP, width, height, PANEL_RADIUS)
            cr.set_source_rgba(0.78, 0.84, 0.91, 0.205)
            cr.fill_preserve()
            cr.clip()

            sheen = cairo.LinearGradient(0, PANEL_TOP, 0, PANEL_BOTTOM)
            sheen.add_color_stop_rgba(0.0, 1.0, 1.0, 1.0, 0.17)
            sheen.add_color_stop_rgba(0.40, 1.0, 1.0, 1.0, 0.055)
            sheen.add_color_stop_rgba(1.0, 0.72, 0.80, 0.90, 0.025)
            cr.set_source(sheen)
            cr.paint()
            if self.pointer_inside:
                # A restrained moving specular highlight: the backdrop remains
                # compositor blur, while only the glass surface reacts to motion.
                glint = cairo.RadialGradient(
                    self.pointer_x, PANEL_TOP + 2.0, 1.0,
                    self.pointer_x, PANEL_TOP + 2.0, 94.0,
                )
                glint.add_color_stop_rgba(0.0, 1.0, 1.0, 1.0, 0.13)
                glint.add_color_stop_rgba(0.45, 1.0, 1.0, 1.0, 0.045)
                glint.add_color_stop_rgba(1.0, 1.0, 1.0, 1.0, 0.0)
                cr.set_source(glint)
                cr.paint()
            cr.reset_clip()

            # Only the upper inner edge catches light; a complete outline turns
            # into the grey halo that real glass panels do not have.
            cr.new_sub_path()
            cr.arc(
                left + PANEL_RADIUS,
                PANEL_TOP + PANEL_RADIUS,
                PANEL_RADIUS - 0.75,
                math.pi,
                3.0 * math.pi / 2.0,
            )
            cr.line_to(left + width - PANEL_RADIUS, PANEL_TOP + 0.75)
            cr.arc(
                left + width - PANEL_RADIUS,
                PANEL_TOP + PANEL_RADIUS,
                PANEL_RADIUS - 0.75,
                -math.pi / 2.0,
                0.0,
            )
            cr.set_line_width(1.0)
            cr.set_source_rgba(1.0, 1.0, 1.0, 0.20)
            cr.stroke()

        def draw_separator(self, cr):
            x = self.layout["separator_x"]
            if x is None:
                return
            cr.set_line_width(1.0)
            cr.set_source_rgba(0.08, 0.10, 0.13, 0.24)
            cr.move_to(x + 0.5, PANEL_TOP + 11.0)
            cr.line_to(x + 0.5, PANEL_BOTTOM - 11.0)
            cr.stroke()

        def draw_drop_preview(self, cr):
            if self.external_drag_active:
                return

            # Internal reordering is represented by a real empty icon slot.
            # Neighbouring icons move aside and the dragged icon follows the
            # pointer, matching Dock behaviour without an insertion line.

        def draw_icon(self, cr, entry, item):
            pixbuf = item["pixbuf"]
            if pixbuf is None:
                return
            if (
                self.internal_remove_armed
                and self.internal_drag_active
                and entry["index"] == self.pressed
            ):
                alpha = 0.62
            elif entry["index"] == self.pressed and not self.internal_drag_active:
                alpha = 0.72
            else:
                alpha = 1.0
            cr.save()
            cr.translate(entry["icon_x"], entry["icon_y"])
            cr.scale(
                entry["icon_size"] / pixbuf.get_width(),
                entry["icon_size"] / pixbuf.get_height(),
            )
            Gdk.cairo_set_source_pixbuf(cr, pixbuf, 0, 0)
            cr.paint_with_alpha(alpha)
            cr.restore()

        def draw_tooltip(self, cr, now):
            if (
                not self.pointer_inside
                or self.hovered is None
                or self.external_drag_active
                or self.internal_drag_active
                or now - self.hover_since < TOOLTIP_DELAY
            ):
                return
            entry = self.layout["items"][self.hovered]
            label = self.items[self.hovered]["label"]
            layout = PangoCairo.create_layout(cr)
            layout.set_text(label, -1)
            layout.set_font_description(Pango.FontDescription("Sans Medium 10.5"))
            text_width, text_height = layout.get_pixel_size()
            width = text_width + 18.0
            height = text_height + 10.0
            x = max(
                4.0,
                min(
                    self.surface_width - width - 4.0,
                    entry["center_x"] - width / 2.0,
                ),
            )
            y = max(3.0, entry["icon_y"] - height - 7.0)

            rounded_rectangle(cr, x, y, width, height, 7.0)
            cr.set_source_rgba(0.11, 0.12, 0.14, 0.88)
            cr.fill()
            cr.set_source_rgba(1.0, 1.0, 1.0, 0.96)
            cr.move_to(x + 9.0, y + 5.0)
            PangoCairo.show_layout(cr, layout)

        def on_draw(self, _widget, cr):
            now = time.monotonic()
            self.layout = self.compute_layout(now)

            cr.set_operator(cairo.OPERATOR_SOURCE)
            cr.set_source_rgba(0.0, 0.0, 0.0, 0.0)
            cr.paint()
            cr.set_operator(cairo.OPERATOR_OVER)

            self.draw_panel(cr)
            self.draw_separator(cr)
            self.draw_drop_preview(cr)

            for entry, item in zip(self.layout["items"], self.items):
                if self.internal_drag_active and entry["index"] == self.pressed:
                    continue
                if item["running"]:
                    cr.arc(entry["center_x"], DOT_Y, 1.65, 0, 2 * math.pi)
                    cr.set_source_rgba(0.07, 0.09, 0.12, 0.72)
                    cr.fill()
                self.draw_icon(cr, entry, item)

            if (
                self.internal_drag_active
                and self.pressed is not None
                and 0 <= self.pressed < len(self.items)
            ):
                entry = self.layout["items"][self.pressed]
                self.draw_icon(cr, entry, self.items[self.pressed])

            self.draw_tooltip(cr, now)
            self.apply_input_region()
            return False

    # Split presentation from reservation.  The visible overlay ignores the
    # 10 px Caelestia border reservation, so it is centred on the physical
    # output and its hit area reaches the real screen edge.  A transparent,
    # non-interactive 1 px surface contributes only the missing work-area strut.
    existing_bottom = hypr_reserved_bottom()
    strut_zone = max(0, EXCLUSIVE_ZONE - existing_bottom)
    strut_window = None

    def draw_clear_surface(_widget, cr):
        cr.set_operator(cairo.OPERATOR_SOURCE)
        cr.set_source_rgba(0.0, 0.0, 0.0, 0.0)
        cr.paint()
        return False

    if strut_zone > 0:
        strut_window = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
        strut_window.set_title("Villode Dock Reservation")
        strut_window.set_decorated(False)
        strut_window.set_resizable(False)
        strut_window.set_accept_focus(False)
        strut_window.set_app_paintable(True)
        strut_window.set_size_request(1, 1)
        strut_window.set_default_size(1, 1)

        screen = strut_window.get_screen()
        visual = screen.get_rgba_visual()
        if visual is not None:
            strut_window.set_visual(visual)

        def remove_strut_input(widget):
            gdk_window = widget.get_window()
            if gdk_window is not None:
                gdk_window.input_shape_combine_region(cairo.Region(), 0, 0)

        strut_window.connect("draw", draw_clear_surface)
        strut_window.connect("realize", remove_strut_input)
        GtkLayerShell.init_for_window(strut_window)
        GtkLayerShell.set_namespace(strut_window, "villode-dock-reserve")
        GtkLayerShell.set_layer(strut_window, GtkLayerShell.Layer.BOTTOM)
        GtkLayerShell.set_keyboard_mode(
            strut_window, GtkLayerShell.KeyboardMode.NONE
        )
        GtkLayerShell.set_anchor(strut_window, GtkLayerShell.Edge.BOTTOM, True)
        GtkLayerShell.set_exclusive_zone(strut_window, strut_zone)

    window = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
    window.set_title("Villode Dock")
    window.set_name("villode-dock")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_app_paintable(True)
    window.set_default_size(SURFACE_WIDTH, WINDOW_HEIGHT)
    window.set_type_hint(Gdk.WindowTypeHint.DOCK)

    screen = window.get_screen()
    visual = screen.get_rgba_visual()
    if visual is not None:
        window.set_visual(visual)

    GtkLayerShell.init_for_window(window)
    GtkLayerShell.set_namespace(window, "villode-dock")
    GtkLayerShell.set_layer(window, GtkLayerShell.Layer.OVERLAY)
    GtkLayerShell.set_keyboard_mode(window, GtkLayerShell.KeyboardMode.NONE)
    GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.BOTTOM, True)
    GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.TOP, False)
    GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.LEFT, False)
    GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.RIGHT, False)
    GtkLayerShell.set_margin(window, GtkLayerShell.Edge.BOTTOM, 0)
    # A negative zone follows the layer-shell protocol's "ignore other
    # exclusive zones" placement mode.  The separate surface above reserves
    # exactly the panel height, without moving this visible overlay.
    GtkLayerShell.set_exclusive_zone(window, -1)

    edge_window = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
    edge_window.set_title("Villode Dock Edge")
    edge_window.set_name("villode-dock-edge")
    edge_window.set_decorated(False)
    edge_window.set_resizable(False)
    edge_window.set_accept_focus(False)
    edge_window.set_app_paintable(True)
    edge_window.set_default_size(SURFACE_WIDTH, 2)
    edge_window.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK)
    edge_visual = edge_window.get_screen().get_rgba_visual()
    if edge_visual is not None:
        edge_window.set_visual(edge_visual)
    edge_window.connect("draw", draw_clear_surface)
    GtkLayerShell.init_for_window(edge_window)
    GtkLayerShell.set_namespace(edge_window, "villode-dock-edge")
    GtkLayerShell.set_layer(edge_window, GtkLayerShell.Layer.OVERLAY)
    GtkLayerShell.set_keyboard_mode(edge_window, GtkLayerShell.KeyboardMode.NONE)
    GtkLayerShell.set_anchor(edge_window, GtkLayerShell.Edge.BOTTOM, True)
    GtkLayerShell.set_exclusive_zone(edge_window, -1)

    display = window.get_display()
    focused_geometry = hypr_focused_monitor_geometry()
    target_monitor = None
    if display is not None and focused_geometry is not None:
        target_monitor = display.get_monitor_at_point(
            int(focused_geometry[0] + focused_geometry[2] / 2),
            int(focused_geometry[1] + focused_geometry[3] / 2),
        )
    if target_monitor is not None:
        GtkLayerShell.set_monitor(window, target_monitor)
        GtkLayerShell.set_monitor(edge_window, target_monitor)
        if strut_window is not None:
            GtkLayerShell.set_monitor(strut_window, target_monitor)

    scene = DockScene(window, strut_window, edge_window)
    window.set_default_size(scene.surface_width, WINDOW_HEIGHT)
    edge_window.set_default_size(scene.surface_width, 2)
    edge_window.set_size_request(scene.surface_width, 2)
    window.add(scene)
    window.connect("destroy", Gtk.main_quit)
    edge_window.connect("enter-notify-event", scene.reveal_fullscreen)

    control_socket = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
    DOCK_CONTROL_SOCKET.parent.mkdir(parents=True, exist_ok=True)
    DOCK_CONTROL_SOCKET.unlink(missing_ok=True)
    control_socket.bind(str(DOCK_CONTROL_SOCKET))
    os.chmod(DOCK_CONTROL_SOCKET, 0o600)
    control_socket.setblocking(False)

    def receive_control_event(_source, condition):
        if condition & (GLib.IO_ERR | GLib.IO_HUP | GLib.IO_NVAL):
            return True
        while True:
            try:
                raw = control_socket.recv(4096)
            except BlockingIOError:
                break
            except OSError:
                return True
            try:
                message = json.loads(raw.decode("utf-8"))
            except (UnicodeDecodeError, json.JSONDecodeError):
                continue
            if not isinstance(message, dict):
                continue
            if message.get("op") == "leave":
                scene.on_custom_drag_leave()
                continue
            if message.get("op") == "drop":
                desktop_id = message.get("desktop_id")
                insertion_index = scene.external_drop_index
                if insertion_index is None:
                    insertion_index = scene.group_break
                if valid_desktop_id(desktop_id):
                    scene.pin_desktop(desktop_id, insertion_index)
                scene.on_custom_drag_leave()
                continue
            if message.get("op") != "drag":
                continue
            try:
                x = float(message["x"])
                y = float(message["y"])
            except (KeyError, TypeError, ValueError):
                continue
            if not math.isfinite(x) or not math.isfinite(y):
                continue
            scene.on_custom_drag_motion(
                max(0.0, min(float(scene.surface_width), x)),
                max(0.0, min(float(WINDOW_HEIGHT), y)),
            )
        return True

    control_watch = GLib.io_add_watch(
        control_socket.fileno(),
        GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP | GLib.IO_NVAL,
        receive_control_event,
    )

    def quit_dock(_signum=None, _frame=None):
        GLib.idle_add(Gtk.main_quit)

    def reload_pins(_signum=None, _frame=None):
        def apply():
            scene.pinned_keys = load_pinned_keys()
            scene.rebuild_items()
            return False

        GLib.idle_add(apply)

    signal.signal(signal.SIGTERM, quit_dock)
    signal.signal(signal.SIGINT, quit_dock)
    signal.signal(signal.SIGHUP, reload_pins)
    if strut_window is not None:
        strut_window.show_all()
    window.show_all()
    GLib.idle_add(scene.request_state_refresh_once)
    try:
        Gtk.main()
    finally:
        if control_watch:
            GLib.source_remove(control_watch)
        control_socket.close()
        DOCK_CONTROL_SOCKET.unlink(missing_ok=True)
    return 0


def main():
    parser = argparse.ArgumentParser(description="Villode Hyprland Dock")
    group = parser.add_mutually_exclusive_group()
    group.add_argument("--run", action="store_true", help="run in the foreground")
    group.add_argument("--daemon", action="store_true", help="start in the background")
    group.add_argument("--toggle", action="store_true", help="toggle the Dock")
    group.add_argument("--reload", action="store_true", help="restart the Dock")
    group.add_argument("--quit", action="store_true", help="stop the Dock")
    group.add_argument(
        "--pin-at",
        nargs=2,
        metavar=("DESKTOP_ID", "SCREEN_X"),
        help="pin an application at a screen X coordinate",
    )
    args = parser.parse_args()

    if args.pin_at:
        desktop_id, screen_x = args.pin_at
        try:
            x = float(screen_x)
        except ValueError:
            return 2
        return 0 if pin_desktop_at_screen_x(desktop_id, x) else 1
    if args.quit:
        stop_running()
        return 0
    if args.reload:
        restart_daemon()
        return 0
    if args.toggle:
        toggle_daemon()
        return 0
    if args.daemon or not args.run:
        start_daemon()
        return 0

    instance_lock = acquire_instance_lock()
    if instance_lock is None:
        return 0
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    write_text_atomic(PID_FILE, f"{os.getpid()}\n")
    try:
        return run_dock()
    finally:
        if read_pid() == os.getpid():
            PID_FILE.unlink(missing_ok=True)
        release_instance_lock(instance_lock)


if __name__ == "__main__":
    raise SystemExit(main())
